{{!
    @template block_playerhud/modal_char
    @package block_playerhud
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "fullname": "Guerreiro Jean",
        "classname": "Guerreiro da Sabedoria",
        "portrait_url": "https://example.com/portrait.png",
        "tier": 2,
        "tier_name": "Iniciado",
        "tier_stars": [
            {"filled": true},
            {"filled": true},
            {"filled": false},
            {"filled": false},
            {"filled": false}
        ],
        "description": "<p>Um guerreiro forjado nos livros e nas batalhas do conhecimento.</p>",
        "karma_data": {
            "value": 30,
            "value_display": "+30",
            "icon_class": "ph-karma--good",
            "label": "Reputação"
        }
    }
}}
<div class="modal fade ph-modal-zindex" id="ph-char-modal" tabindex="-1"
     aria-labelledby="phCharModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header">
                <h2 class="modal-title h5 fw-bold m-0" id="phCharModalLabel">{{fullname}}</h2>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal" data-dismiss="modal"
                        aria-label="{{#str}} close, block_playerhud {{/str}}">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    {{#portrait_url}}
                    <img src="{{portrait_url}}" alt="{{classname}}"
                         class="flex-shrink-0"
                         width="120" height="120">
                    {{/portrait_url}}
                    {{^portrait_url}}
                    <i class="fa fa-user-circle fa-4x text-secondary flex-shrink-0" aria-hidden="true"></i>
                    {{/portrait_url}}
                    <div>
                        <div class="ph-tier-stars mb-1" role="img"
                             aria-label="{{tier_name}}: {{tier}} {{#str}} out_of_5, block_playerhud {{/str}}">
                            {{#tier_stars}}{{#filled}}★{{/filled}}{{^filled}}☆{{/filled}}{{/tier_stars}}
                        </div>
                        <div class="ph-tier-name">{{tier_name}}</div>
                    </div>
                </div>
                <div class="ph-char-modal-desc">{{{description}}}</div>
                {{#karma_data}}
                <div class="ph-karma-inline {{icon_class}} mt-3 pt-2 border-top"
                     aria-label="{{label}}: {{value_display}}">
                    <i class="fa fa-balance-scale me-1" aria-hidden="true"></i>
                    <span class="fw-semibold">{{label}}:</span> {{value_display}}
                </div>
                {{/karma_data}}
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal" data-dismiss="modal">
                    {{#str}} close, block_playerhud {{/str}}
                </button>
            </div>

        </div>
    </div>
</div>
