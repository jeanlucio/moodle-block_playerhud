{{!
    Recap view of a completed story chapter — shows all visited scenes in order.

    @template   block_playerhud/story_recap
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "scenes": [
            {"content": "<p>You entered the dark forest...</p>"},
            {"content": "<p>A wolf appeared before you.</p>"}
        ],
        "str_end": "The End"
    }
}}
<div class="ph-recap-container">
    {{#scenes}}
    <div class="ph-recap-scene mb-4 pb-3 border-bottom">
        {{{content}}}
    </div>
    {{/scenes}}
    <div class="text-center text-muted fst-italic mt-3">
        <i class="fa fa-check" aria-hidden="true"></i> {{str_end}}
    </div>
</div>
