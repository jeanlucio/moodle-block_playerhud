{{!
    @template block_playerhud/manage_quests

    Displays the quest management list.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "url_add": "#",
        "str_add_quest": "New Quest",
        "str_actions": "Actions",
        "str_edit": "Edit",
        "str_delete": "Delete",
        "str_empty": "No quests created.",
        "str_select_all": "Select all",
        "str_select": "Select",
        "str_delete_selected": "Delete Selected",
        "headers": {
            "name":    { "url": "#", "label": "Name",    "icon_class": "fa-sort" },
            "type":    { "url": "#", "label": "Type",    "icon_class": "fa-sort" },
            "reward":  { "url": "#", "label": "Reward",  "icon_class": "fa-sort" },
            "claims":  { "url": "#", "label": "Claims",  "icon_class": "fa-sort" },
            "enabled": { "url": "#", "label": "Enabled", "icon_class": "fa-sort" }
        },
        "base_url": "#",
        "sesskey": "abc123",
        "summary_text": "3 quests created.",
        "summary_hint": "Quests are checked automatically: when the student reaches the objective, the reward is granted instantly.",
        "has_quests": true,
        "paging_bar": "",
        "quests": [
            {
                "id": 1,
                "counter": 1,
                "image_todo": "📋",
                "name": "Reach Level 5",
                "type_label": "Reach Level",
                "type_badge_class": "bg-primary text-white",
                "requirement_text": "5",
                "enabled": true,
                "str_yes": "Yes",
                "str_no": "No",
                "str_hide": "Hide",
                "str_show": "Show",
                "reward_text": "50 XP",
                "claims_count": 3,
                "url_edit": "#",
                "url_toggle": "#",
                "url_delete": "#",
                "str_delete_confirm": "Are you sure you want to delete &#x27;Reach Level 5&#x27;?"
            }
        ]
    }
}}
<div class="block_playerhud">
    <div class="d-flex flex-column mb-3 p-3 bg-light rounded border shadow-sm ph-manage-header">
        <div class="d-flex justify-content-between align-items-center w-100 flex-wrap gap-2">
            <div class="d-flex align-items-center flex-grow-1">
                <button class="btn btn-link p-0 text-primary text-decoration-none me-2" type="button"
                        data-toggle="collapse" data-bs-toggle="collapse"
                        data-target="#ph-quests-hint" data-bs-target="#ph-quests-hint"
                        aria-expanded="false" aria-controls="ph-quests-hint"
                        aria-label="{{#str}} help_btn, block_playerhud {{/str}}">
                    <i class="fa fa-question-circle fa-lg" aria-hidden="true"></i>
                </button>
                <span class="fw-bold text-dark">{{summary_text}}</span>
            </div>
            <div class="d-flex flex-shrink-0">
                {{#url_suggest}}
                <a href="{{url_suggest}}" class="btn btn-info text-white shadow-sm me-2">
                    <i class="fa fa-magic me-1" aria-hidden="true"></i> {{str_suggest}}
                </a>
                {{/url_suggest}}
                <a href="{{url_add}}" class="btn btn-primary shadow-sm">
                    <i class="fa fa-plus-circle me-1" aria-hidden="true"></i> {{str_add_quest}}
                </a>
            </div>
        </div>
        <div class="collapse w-100" id="ph-quests-hint">
            <div class="alert alert-info border-info mb-0 mt-3 small py-2 shadow-sm d-flex align-items-start">
                <i class="fa fa-lightbulb-o fa-lg me-2 mt-1 text-warning" aria-hidden="true"></i>
                <div>{{summary_hint}}</div>
            </div>
        </div>
    </div>

    {{#has_quests}}
    <form action="{{base_url}}" method="post" id="bulk-action-form">
        <input type="hidden" name="action" value="bulk_delete_quests">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-sm align-middle mb-0">
                        <thead class="bg-light border-bottom">
                            <tr class="text-nowrap">
                                <th scope="col" class="ph-col-select text-center align-middle">
                                    <input type="checkbox" id="ph-select-all" class="form-check-input"
                                        title="{{str_select_all}}" aria-label="{{str_select_all}}">
                                </th>
                                <th scope="col" class="ph-col-sm text-center">{{#str}} col_number, block_playerhud {{/str}}</th>
                                <th scope="col">
                                    <a href="{{headers.name.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                        {{headers.name.label}}
                                        <i class="fa {{headers.name.icon_class}} ms-1" aria-hidden="true"></i>
                                    </a>
                                </th>
                                <th scope="col">
                                    <a href="{{headers.type.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                        {{headers.type.label}}
                                        <i class="fa {{headers.type.icon_class}} ms-1" aria-hidden="true"></i>
                                    </a>
                                </th>
                                <th scope="col">
                                    <a href="{{headers.reward.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                        {{headers.reward.label}}
                                        <i class="fa {{headers.reward.icon_class}} ms-1" aria-hidden="true"></i>
                                    </a>
                                </th>
                                <th scope="col" class="text-center">
                                    <a href="{{headers.claims.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center justify-content-center">
                                        {{headers.claims.label}}
                                        <i class="fa {{headers.claims.icon_class}} ms-1" aria-hidden="true"></i>
                                    </a>
                                </th>
                                <th scope="col" class="text-center">
                                    <a href="{{headers.enabled.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center justify-content-center">
                                        {{headers.enabled.label}}
                                        <i class="fa {{headers.enabled.icon_class}} ms-1" aria-hidden="true"></i>
                                    </a>
                                </th>
                                <th scope="col" class="text-end pe-3">{{str_actions}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#quests}}
                            <tr{{^enabled}} class="opacity-50"{{/enabled}}>
                                <td class="ph-col-select text-center align-middle">
                                    <input type="checkbox" name="bulk_ids[]" value="{{id}}" id="chk-quest-{{id}}"
                                        class="form-check-input ph-bulk-check" aria-label="{{str_select}} {{name}}">
                                </td>
                                <td class="align-middle text-center text-muted small text-nowrap">{{counter}}</td>
                                <td class="align-middle">
                                    <span class="ph-quest-icon-cell me-1" aria-hidden="true">{{image_todo}}</span>
                                    <span class="fw-semibold">{{name}}</span>
                                </td>
                                <td class="align-middle">
                                    <span class="badge {{type_badge_class}}">{{type_label}} = {{requirement_text}}</span>
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-primary text-white">{{reward_text}}</span>
                                </td>
                                <td class="align-middle text-center">
                                    <span class="badge bg-light text-dark border">{{claims_count}}</span>
                                </td>
                                <td class="align-middle text-nowrap text-center">
                                    {{#enabled}}
                                        <span class="badge bg-success text-white">{{str_yes}}</span>
                                        <a href="{{url_toggle}}" class="btn btn-sm btn-light border ms-1" aria-label="{{str_hide}} {{name}}">
                                            <i class="fa fa-eye text-success" aria-hidden="true"></i>
                                        </a>
                                    {{/enabled}}
                                    {{^enabled}}
                                        <span class="badge bg-secondary text-white">{{str_no}}</span>
                                        <a href="{{url_toggle}}" class="btn btn-sm btn-warning ms-1" aria-label="{{str_show}} {{name}}">
                                            <i class="fa fa-eye-slash" aria-hidden="true"></i>
                                        </a>
                                    {{/enabled}}
                                </td>
                                <td class="align-middle text-end text-nowrap pe-3">
                                    <a href="{{url_edit}}"
                                       class="btn btn-sm btn-primary me-1 shadow-sm"
                                       aria-label="{{str_edit}} {{name}}">
                                        <i class="fa fa-pencil" aria-hidden="true"></i>
                                        <span class="d-none d-xl-inline ms-1">{{str_edit}}</span>
                                    </a>
                                    <a href="{{url_delete}}"
                                       class="btn btn-sm btn-danger shadow-sm js-delete-btn"
                                       aria-label="{{str_delete}} {{name}}"
                                       data-confirm-msg="{{str_delete_confirm}}">
                                        <i class="fa fa-trash" aria-hidden="true"></i>
                                        <span class="d-none d-xl-inline ms-1">{{str_delete}}</span>
                                    </a>
                                </td>
                            </tr>
                            {{/quests}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-danger shadow-sm disabled" id="ph-btn-bulk-delete" disabled>
                <i class="fa fa-trash me-1" aria-hidden="true"></i> {{str_delete_selected}}
            </button>
        </div>
    </form>

    {{{paging_bar}}}
    {{/has_quests}}

    {{^has_quests}}
    <div class="alert alert-info">
        <i class="fa fa-info-circle me-1" aria-hidden="true"></i>
        {{str_empty}}
    </div>
    {{/has_quests}}
</div>
