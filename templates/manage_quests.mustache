{{!
    @template block_playerhud/manage_quests

    Displays the quest management list.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "url_add": "#",
        "str_add_quest": "New Quest",
        "str_col_icon": "Icon",
        "str_col_reward": "Rewards",
        "str_col_claims": "Claims",
        "str_col_enabled": "Enabled?",
        "str_col_req": "Target",
        "str_actions": "Actions",
        "str_edit": "Edit",
        "str_delete": "Delete",
        "str_empty": "No quests created.",
        "headers": {
            "name": { "url": "#", "label": "Name", "icon_class": "fa-sort" },
            "type": { "url": "#", "label": "Type", "icon_class": "fa-sort" },
            "date": { "url": "#", "label": "Date", "icon_class": "fa-sort" }
        },
        "has_quests": true,
        "quests": [
            {
                "id": 1,
                "image_todo": "📋",
                "name": "Reach Level 5",
                "type_label": "Reach Level",
                "type_badge_class": "bg-primary text-white",
                "requirement_text": "5",
                "enabled": true,
                "reward_text": "50 XP",
                "claims_count": 3,
                "url_edit": "#",
                "url_toggle": "#",
                "url_delete": "#",
                "str_toggle": "Click to hide",
                "str_delete_confirm": "Are you sure you want to delete &#x27;Reach Level 5&#x27;?"
            }
        ]
    }
}}
<div class="block_playerhud">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="{{url_add}}" class="btn btn-primary">
            <i class="fa fa-plus me-1" aria-hidden="true"></i>
            {{str_add_quest}}
        </a>
    </div>

    {{#has_quests}}
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-center">{{str_col_icon}}</th>
                    <th scope="col">
                        <a href="{{headers.name.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                            {{headers.name.label}}
                            <i class="fa {{headers.name.icon_class}} ms-1" aria-hidden="true"></i>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{headers.type.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                            {{headers.type.label}}
                            <i class="fa {{headers.type.icon_class}} ms-1" aria-hidden="true"></i>
                        </a>
                    </th>
                    <th scope="col">{{str_col_req}}</th>
                    <th scope="col">{{str_col_reward}}</th>
                    <th scope="col" class="text-center">{{str_col_claims}}</th>
                    <th scope="col" class="text-center">{{str_col_enabled}}</th>
                    <th scope="col" class="text-end">{{str_actions}}</th>
                </tr>
            </thead>
            <tbody>
                {{#quests}}
                <tr>
                    <td class="text-center ph-quest-icon-cell" aria-hidden="true">{{image_todo}}</td>
                    <td class="fw-semibold">{{name}}</td>
                    <td>
                        <span class="badge {{type_badge_class}}">{{type_label}}</span>
                    </td>
                    <td class="text-muted small">{{requirement_text}}</td>
                    <td class="text-muted small">{{reward_text}}</td>
                    <td class="text-center">
                        <span class="badge bg-light text-dark border">{{claims_count}}</span>
                    </td>
                    <td class="text-center">
                        <a href="{{url_toggle}}"
                           class="btn btn-sm {{#enabled}}btn-success{{/enabled}}{{^enabled}}btn-outline-secondary{{/enabled}}"
                           aria-label="{{str_toggle}}">
                            <i class="fa {{#enabled}}fa-eye{{/enabled}}{{^enabled}}fa-eye-slash{{/enabled}}"
                               aria-hidden="true"></i>
                        </a>
                    </td>
                    <td class="text-end">
                        <a href="{{url_edit}}"
                           class="btn btn-sm btn-outline-primary me-1"
                           aria-label="{{str_edit}} {{name}}">
                            <i class="fa fa-pencil" aria-hidden="true"></i>
                            <span class="d-none d-xl-inline ms-1">{{str_edit}}</span>
                        </a>
                        <a href="{{url_delete}}"
                           class="btn btn-sm btn-danger shadow-sm js-delete-btn"
                           aria-label="{{str_delete}} {{name}}"
                           data-confirm-msg="{{str_delete_confirm}}">
                            <i class="fa fa-trash" aria-hidden="true"></i>
                            <span class="d-none d-xl-inline ms-1">{{str_delete}}</span>
                        </a>
                    </td>
                </tr>
                {{/quests}}
            </tbody>
        </table>
    </div>
    {{/has_quests}}

    {{^has_quests}}
    <div class="alert alert-info">
        <i class="fa fa-info-circle me-1" aria-hidden="true"></i>
        {{str_empty}}
    </div>
    {{/has_quests}}
</div>
