{{!
    @template block_playerhud/tab_history

    History tab output renderer for students.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str": {
            "title": "History",
            "desc": "Check your recent game actions.",
            "empty": "No logs.",
            "col_date": "Date",
            "col_type": "Type",
            "col_desc": "Element",
            "xp": "XP",
            "col_details": "Details",
            "btn_showall": "Show all",
            "btn_showpaged": "Show 30 per page"
        },
        "filters": {
            "action_url": "#",
            "courseid": 1,
            "instanceid": 1,
            "types": [
                {"value": "", "label": "All", "selected": true},
                {"value": "item", "label": "Items", "selected": false}
            ],
            "text": ""
        },
        "headers": {
            "date": {"url": "#", "label": "Date", "icon_class": "fa-sort"},
            "type": {"url": "#", "label": "Type", "icon_class": "fa-sort"},
            "element": {"url": "#", "label": "Element", "icon_class": "fa-sort"},
            "xp": {"url": "#", "label": "XP", "icon_class": "fa-sort"},
            "details": {"url": "#", "label": "Details", "icon_class": "fa-sort"}
        },
        "showall": false,
        "url_toggle_showall": "#",
        "has_logs": true,
        "logs": [
            {
                "counter": 1,
                "date": "10 Jan 2026",
                "badge_class": "bg-primary",
                "badge_text": "Item",
                "is_image_icon": true,
                "icon_url": "https://example.com/icon.png",
                "icon_emoji": "",
                "object_name": "Magic Sword",
                "xp_badge": "<span class=\"badge bg-success text-white\">+100 XP</span>",
                "details_html": "Found on map"
            }
        ],
        "paging_bar": "<nav>Pagination</nav>"
    }
}}
<div class="playerhud-history-container animate__animated animate__fadeIn">

    <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        <div>{{str.desc}}</div>
    </div>

    {{! --- LIVE SEARCH BAR & SHOW ALL TOGGLE --- }}
    <div class="mb-4 d-flex gap-2 flex-wrap">
        <div class="input-group shadow-sm flex-grow-1 ph-min-w-250">
            <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted" aria-hidden="true"></i></span>
            <input type="text" id="ph-live-search" class="form-control border-start-0 ps-0" placeholder="{{str.search_any}}" aria-label="{{str.search_any}}">
        </div>
        <div class="flex-shrink-0">
            {{#showall}}
                <a href="{{url_toggle_showall}}" class="btn btn-outline-primary shadow-sm h-100 d-flex align-items-center text-nowrap">
                    <i class="fa fa-compress me-2" aria-hidden="true"></i> {{str.btn_showpaged}}
                </a>
            {{/showall}}
            {{^showall}}
                <a href="{{url_toggle_showall}}" class="btn btn-outline-secondary shadow-sm h-100 d-flex align-items-center text-nowrap">
                    <i class="fa fa-expand me-2" aria-hidden="true"></i> {{str.btn_showall}}
                </a>
            {{/showall}}
        </div>
    </div>

    {{#has_logs}}
        <div class="table-responsive shadow-sm rounded mb-3 border">
            <table class="table table-hover table-striped bg-white mb-0 align-middle w-100">
                <thead class="bg-light border-bottom">
                    <tr class="text-nowrap">
                        <th scope="col" class="text-center text-muted ph-w-50">{{str.col_num}}</th>
                        <th scope="col">
                            <a href="{{headers.date.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                {{headers.date.label}} <i class="fa {{headers.date.icon_class}}" aria-hidden="true"></i>
                            </a>
                        </th>
                        <th scope="col">
                            <a href="{{headers.type.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                {{headers.type.label}} <i class="fa {{headers.type.icon_class}}" aria-hidden="true"></i>
                            </a>
                        </th>
                        <th scope="col">
                            <a href="{{headers.element.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                {{headers.element.label}} <i class="fa {{headers.element.icon_class}}" aria-hidden="true"></i>
                            </a>
                        </th>
                        <th scope="col" class="text-center">
                            <a href="{{headers.xp.url}}" class="text-dark text-decoration-none d-flex align-items-center justify-content-center">
                                {{headers.xp.label}} <i class="fa {{headers.xp.icon_class}}" aria-hidden="true"></i>
                            </a>
                        </th>
                        <th scope="col">
                            <a href="{{headers.details.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                {{headers.details.label}} <i class="fa {{headers.details.icon_class}}" aria-hidden="true"></i>
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody id="ph-history-tbody">
                    {{#logs}}
                    <tr class="ph-searchable-row">
                        <td class="text-center text-muted small">{{counter}}</td>
                        <td class="text-muted small text-nowrap">{{date}}</td>
                        <td><span class="badge {{badge_class}}">{{badge_text}}</span></td>
                        <td class="fw-bold">
                            <div class="d-flex align-items-center">
                                <div class="me-2 text-center ph-w-30">
                                    {{#is_image_icon}}<img src="{{icon_url}}" class="ph-img-xs" alt="">{{/is_image_icon}}
                                    {{^is_image_icon}}<span class="fs-5" aria-hidden="true">{{icon_emoji}}</span>{{/is_image_icon}}
                                </div>
                                <div>{{object_name}}</div>
                            </div>
                        </td>
                        <td class="text-center">{{{xp_badge}}}</td>
                        <td class="text-muted small text-wrap ph-table-details-col">{{{details_html}}}</td>
                    </tr>
                    {{/logs}}
                </tbody>
            </table>
        </div>

        {{! --- RENDER PAGINATION BAR --- }}
        {{{paging_bar}}}

    {{/has_logs}}

    {{^has_logs}}
        <div class="alert alert-info text-center p-5 shadow-sm">
            <div class="display-4 text-muted ph-opacity-low mb-3" aria-hidden="true">📭</div>
            <h5 class="text-muted">{{str.empty}}</h5>
        </div>
    {{/has_logs}}

</div>
