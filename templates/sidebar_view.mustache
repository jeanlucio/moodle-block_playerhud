{{!
    @template block_playerhud/sidebar_view
    @package block_playerhud
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "userpicture": "<img src='user.jpg' alt='User Profile Picture'>",
        "username": "Student Name",
        "level_class": "ph-lvl-tier-1",
        "level": "1 / 10",
        "xp": "100 / 500 XP",
        "viewurl": "#",
        "url_history": "#",
        "url_shop": "#",
        "url_quests": "#",
        "url_story": "#",
        "progress": 20,
        "isteacher": false,
        "manageurl": "#",
        "has_items": true,
        "items": [
            {
                "name": "Potion",
                "xp": "50 XP",
                "isimage": false,
                "image": "🧪",
                "description": "Mana restore"
            }
        ],
        "classdata": {
            "classname": "Mage",
            "fullname": "Mage Jean",
            "portrait_url": "https://example.com/portrait.png",
            "tier": 2,
            "tier_name": "Initiate",
            "tier_stars": [
                {"filled": true},
                {"filled": true},
                {"filled": false},
                {"filled": false},
                {"filled": false}
            ],
            "description": "<p>A mage of great wisdom and arcane power.</p>",
            "has_description": true
        },
        "karma_data": {
            "value": 30,
            "value_display": "+30",
            "percent": 65,
            "bar_class": "ph-karma-fill--good",
            "icon_class": "ph-karma--good",
            "label": "Fate / Karma"
        },
        "url_class_select": "#",
        "ranking": {
            "url": "#",
            "tooltip": "Rank #1",
            "label": "Leaderboard"
        },
        "url_disable": "#",
        "str_confirm_msg": "Sure?",
        "str_disable_gamification": "Disable"
    }
}}
<div class="block_playerhud_sidebar p-2">

    {{! ── CARD 1: COURSE PROGRESS ── }}

    {{! Top shortcut buttons: history and help — hoisted into block title by view.js }}
    <div class="ph-header-actions d-flex align-items-center gap-1">
        <a href="{{url_history}}" class="ph-help-trigger"
           title="{{#str}} tab_history, block_playerhud {{/str}}"
           aria-label="{{#str}} tab_history, block_playerhud {{/str}}">
            <i class="fa fa-list-alt" aria-hidden="true"></i>
        </a>
        <a href="{{viewurl}}&tab=rules" class="ph-help-trigger ms-1"
           title="{{#str}} help_btn, block_playerhud {{/str}}"
           aria-label="{{#str}} help_btn, block_playerhud {{/str}}">
            <i class="fa fa-question-circle" aria-hidden="true"></i>
        </a>
    </div>

    {{! Profile picture + name }}
    <div class="text-center mb-2">
        <div class="mb-1 ph-sidebar-avatar-container">
            {{{userpicture}}}
        </div>
        <div class="fw-bold text-truncate px-1 small" title="{{username}}">
            {{username}}
        </div>
    </div>

    {{! Stats: level + XP }}
    <div class="d-flex justify-content-between align-items-center mb-1 small px-1">
        <span class="badge {{level_class}} border">{{#str}} level, block_playerhud {{/str}} {{level}}</span>
        <span class="badge rounded-pill {{level_class}}">{{xp}}</span>
    </div>

    <div class="progress ph-progress-container mb-3">
        <div class="progress-bar ph-progress-bar {{level_class}}" role="progressbar"
             style="--ph-progress: {{progress}}%;"
             aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100">
             <span class="ph-progress-text">{{progress}}%</span>
        </div>
    </div>

    {{! Master Panel button }}
    {{#isteacher}}
    <div class="mb-3">
        <a href="{{{manageurl}}}" class="btn btn-outline-dark btn-sm w-100 shadow-sm fw-bold">
            <i class="fa fa-cogs me-2" aria-hidden="true"></i> {{#str}} master_panel, block_playerhud {{/str}}
        </a>
    </div>
    {{/isteacher}}

    {{! Action grid }}
    <div class="ph-sidebar-grid mb-4 {{level_class}}">

        <a href="{{viewurl}}"
           class="btn btn-ph-level-border shadow-sm"
           data-bs-toggle="tooltip" data-bs-placement="top"
           title="{{#str}} openbackpack, block_playerhud {{/str}}"
           aria-label="{{#str}} openbackpack, block_playerhud {{/str}}">
            <span aria-hidden="true">🎒</span>
        </a>

        <a href="{{url_shop}}"
           class="btn btn-ph-level-border shadow-sm"
           data-bs-toggle="tooltip" data-bs-placement="bottom"
           title="{{#str}} tab_shop, block_playerhud {{/str}}"
           aria-label="{{#str}} tab_shop, block_playerhud {{/str}}">
            <span aria-hidden="true">🛒</span>
        </a>

        <a href="{{url_quests}}"
           class="btn btn-ph-level-border shadow-sm position-relative"
           data-bs-toggle="tooltip" data-bs-placement="bottom"
           title="{{#str}} tab_quests, block_playerhud {{/str}}"
           aria-label="{{#str}} tab_quests, block_playerhud {{/str}}">
            <span aria-hidden="true">🎯</span>
            {{#has_claimable_quests}}
            <span class="ph-quest-notify-dot" aria-hidden="true"></span>
            {{/has_claimable_quests}}
        </a>

        <a href="{{url_story}}"
           class="btn btn-ph-level-border shadow-sm position-relative"
           data-bs-toggle="tooltip" data-bs-placement="bottom"
           title="{{#str}} story_shortcut, block_playerhud {{/str}}"
           aria-label="{{#str}} story_shortcut, block_playerhud {{/str}}">
            <span aria-hidden="true">📖</span>
            {{#has_unread_chapters}}
            <span class="ph-quest-notify-dot" aria-hidden="true"></span>
            {{/has_unread_chapters}}
        </a>

        {{#ranking}}
        <a href="{{url}}"
           class="btn btn-ph-level-border shadow-sm"
           data-bs-toggle="tooltip" data-bs-placement="bottom"
           title="{{tooltip}}"
           aria-label="{{label}}">
            <span aria-hidden="true">🏆</span>
        </a>
        {{/ranking}}

        <a href="{{url_disable}}"
           class="btn btn-ph-level-border shadow-sm js-disable-hud"
           data-bs-toggle="tooltip" data-bs-placement="bottom"
           data-confirm-msg="{{str_confirm_msg}}"
           title="{{str_disable_gamification}}"
           aria-label="{{str_disable_gamification}}">
            <span aria-hidden="true" class="text-danger">
                 <i class="fa fa-power-off"></i>
            </span>
        </a>

    </div>

    {{! Recent items }}
    <div class="ph-stash-wrapper {{^has_items}}d-none{{/has_items}}">
        <div class="ph-sidebar-stash mt-1 justify-content-center">
            {{#items}}
            <div class="ph-mini-item ph-item-trigger"
                 role="button"
                 tabindex="0"
                 data-name="{{name}}"
                 data-xp="{{xp}}"
                 data-image="{{image}}"
                 data-isimage="{{isimage}}"
                 data-date="{{date}}"
                 data-timestamp="{{timestamp}}"
                 title="{{name}}"
                 aria-label="{{name}}">

                 <div class="d-none ph-item-description-content">{{{description}}}</div>

                 {{#isimage}}
                    <img src="{{image}}" alt="" class="ph-mini-item-img">
                 {{/isimage}}
                 {{^isimage}}
                    <span class="ph-emoji" aria-hidden="true">{{image}}</span>
                 {{/isimage}}
            </div>
            {{/items}}
        </div>
    </div>

    {{! ── CARD 2: CHARACTER (RPG mode only) ── }}
    {{#enable_rpg}}
    {{#classdata}}

    <hr class="ph-section-divider mt-3">

    <div class="ph-char-card p-2 mt-2">

        {{! Portrait + identity — clickable to open lore modal when a description is set }}
        {{#has_description}}
        <button type="button"
                class="ph-char-identity ph-char-identity--clickable mb-2 border-0 bg-transparent p-0 w-100 text-start"
                data-bs-toggle="modal" data-bs-target="#ph-char-modal"
                data-toggle="modal" data-target="#ph-char-modal"
                aria-haspopup="dialog">
        {{/has_description}}
        {{^has_description}}
        <div class="ph-char-identity mb-2">
        {{/has_description}}

            {{! Portrait }}
            <div class="ph-char-portrait-wrap">
                {{#portrait_url}}
                <img src="{{portrait_url}}" alt="{{classname}}" class="ph-char-portrait">
                {{/portrait_url}}
                {{^portrait_url}}
                <i class="fa fa-user-circle ph-char-portrait-fallback" aria-hidden="true"></i>
                {{/portrait_url}}
            </div>

            {{! Name + tier + stars + karma }}
            <div class="ph-char-info">
                <div class="fw-bold ph-char-fullname" title="{{fullname}}">
                    {{fullname}}
                </div>
                <div class="ph-tier-name">{{tier_name}}</div>
                <div class="ph-tier-stars" role="img"
                     aria-label="{{tier_name}}: {{tier}} {{#str}} out_of_5, block_playerhud {{/str}}">
                    {{#tier_stars}}{{#filled}}★{{/filled}}{{^filled}}☆{{/filled}}{{/tier_stars}}
                </div>
                {{#karma_data}}
                <div class="ph-karma-inline {{icon_class}}"
                     aria-label="{{label}}: {{value_display}}">
                    <i class="fa fa-balance-scale me-1" aria-hidden="true"></i>{{value_display}}
                </div>
                {{/karma_data}}
            </div>

        {{#has_description}}
        </button>
        {{/has_description}}
        {{^has_description}}
        </div>
        {{/has_description}}

    </div>

    {{> block_playerhud/modal_char }}

    {{/classdata}}

    {{/enable_rpg}}

</div>
