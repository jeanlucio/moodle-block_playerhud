{{!
    @template block_playerhud/tab_trades

    Trades management tab output template for PlayerHUD.
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="h5 text-muted m-0 fw-bold">{{str_title}}</h3>
    <a href="{{url_add}}" class="btn btn-success shadow-sm fw-bold">
        <i class="fa fa-plus me-1" aria-hidden="true"></i> {{str_add}}
    </a>
</div>

<div class="row">
    {{#has_trades}}
        {{#trades}}
        <div class="col-lg-6 col-12 mb-4 d-flex justify-content-center">
            <div class="card ph-trade-widget-card shadow-sm h-100 w-100">

                {{! TRADE HEADER }}
                <div class="card-header bg-light d-flex flex-wrap justify-content-between align-items-center border-bottom py-2">
                    <div class="d-flex align-items-center mb-2 mb-md-0">
                        {{#is_centralized}}
                            <span class="badge bg-primary text-white shadow-sm">{{str_shop}}</span>
                        {{/is_centralized}}
                        {{^is_centralized}}
                            <span class="badge bg-secondary text-white shadow-sm">{{str_hidden}}</span>
                        {{/is_centralized}}
                        {{#is_onetime}}
                            <span class="badge bg-warning text-dark shadow-sm ms-1"><i class="fa fa-asterisk" aria-hidden="true"></i> {{str_onetime}}</span>
                        {{/is_onetime}}
                        <span class="fw-bold ms-2 text-dark">{{name}}</span>
                    </div>
                    <div class="d-flex gap-1">
                        <a href="{{url_edit}}" class="btn btn-sm btn-primary shadow-sm" aria-label="{{str_edit}}">
                            <i class="fa fa-pencil" aria-hidden="true"></i> <span class="d-none d-xl-inline ms-1">{{str_edit}}</span>
                        </a>
                        <a href="{{url_delete}}" class="btn btn-sm btn-danger shadow-sm js-delete-btn"
                           data-confirm-msg="{{confirm_msg}}" aria-label="{{str_delete}}">
                            <i class="fa fa-trash" aria-hidden="true"></i> <span class="d-none d-xl-inline ms-1">{{str_delete}}</span>
                        </a>
                    </div>
                </div>

                {{! TRADE BODY (Idêntico ao do aluno) }}
                <div class="card-body p-3 d-flex flex-column">
                    <div class="row align-items-center flex-grow-1">
                        <div class="col-5 text-center px-1">
                            <div class="text-danger small fw-bold text-uppercase mb-2 ph-trade-label">
                                <i class="fa fa-minus-circle me-1" aria-hidden="true"></i>{{str_pay}}
                            </div>
                            <div class="d-flex flex-column gap-2 align-items-center">
                                {{#requirements}}
                                <div class="badge bg-white text-dark border d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                    <div class="me-2 flex-shrink-0 bg-light border rounded ph-trade-icon-box">
                                        {{#is_image}}
                                            <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain p-1">
                                        {{/is_image}}
                                        {{^is_image}}
                                            <span class="fs-4" aria-hidden="true">{{image_content}}</span>
                                        {{/is_image}}
                                    </div>
                                    <div class="text-truncate ph-min-w-0">
                                        <span class="fw-bold fs-6">{{qty}}x</span>
                                        <span class="fw-normal">{{name}}</span>
                                    </div>
                                </div>
                                {{/requirements}}
                            </div>
                        </div>

                        <div class="col-2 text-center text-muted px-0">
                            <i class="fa fa-arrow-right fs-5" aria-hidden="true"></i>
                        </div>

                        <div class="col-5 text-center px-1">
                            <div class="text-success small fw-bold text-uppercase mb-2 ph-trade-label">
                                <i class="fa fa-plus-circle me-1" aria-hidden="true"></i>{{str_receive}}
                            </div>
                            <div class="d-flex flex-column gap-2 align-items-center">
                                {{#rewards}}
                                <div class="badge bg-white text-dark border border-success d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                    <div class="me-2 flex-shrink-0 bg-success bg-opacity-10 border border-success rounded ph-trade-icon-box">
                                        {{#is_image}}
                                            <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain p-1">
                                        {{/is_image}}
                                        {{^is_image}}
                                            <span class="fs-4" aria-hidden="true">{{image_content}}</span>
                                        {{/is_image}}
                                    </div>
                                    <div class="text-truncate ph-min-w-0">
                                        <span class="fw-bold fs-6">{{qty}}x</span>
                                        <span class="fw-normal">{{name}}</span>
                                    </div>
                                </div>
                                {{/rewards}}
                            </div>
                        </div>
                    </div>
                </div>

                {{! FOOTER (SHORTCODE) }}
                <div class="card-footer bg-light border-top p-2">
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control font-monospace text-center text-muted bg-white border-end-0"
                               value="{{shortcode}}" readonly id="code_{{id}}">
                        <button class="btn btn-outline-secondary" type="button"
                                data-action="copytoclipboard"
                                data-clipboard-target="#code_{{id}}">
                            <i class="fa fa-copy me-1" aria-hidden="true"></i> {{str_copy}}
                        </button>
                    </div>
                </div>

            </div>
        </div>
        {{/trades}}
    {{/has_trades}}

    {{^has_trades}}
        <div class="col-12 text-center py-5 text-muted">
            <div style="font-size: 3rem; opacity: 0.3;" aria-hidden="true">⚖️</div>
            <p class="mt-3">{{str_empty}}</p>
        </div>
    {{/has_trades}}
</div>
