{{!
    @template block_playerhud/tab_trades

    Trades management tab output template for PlayerHUD.
    @package    block_playerhud
    @copyright  2026 Jean Lúcio
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_title": "Trade Configuration",
        "summary_text": "You have 3 trade offer(s) created.",
        "summary_hint": "Trade offers define NPC negotiation rules: the student pays items and receives another in return.",
        "url_add": "#",
        "str_add": "New Trade",
        "has_trades": false,
        "str_empty": "No trades registered."
    }
}}
<div class="d-flex flex-column mb-3 p-3 bg-light rounded border shadow-sm ph-manage-header">
    <div class="d-flex justify-content-between align-items-center w-100 flex-wrap gap-2">
        <div class="d-flex align-items-center flex-grow-1">
            <button class="btn btn-link p-0 text-primary text-decoration-none me-2" type="button"
                    data-toggle="collapse" data-bs-toggle="collapse"
                    data-target="#ph-trades-hint" data-bs-target="#ph-trades-hint"
                    aria-expanded="false" aria-controls="ph-trades-hint"
                    aria-label="{{#str}} help_btn, block_playerhud {{/str}}">
                <i class="fa fa-question-circle fa-lg" aria-hidden="true"></i>
            </button>
            <span class="fw-bold text-dark">{{summary_text}}</span>
        </div>
        <div class="d-flex flex-shrink-0">
            <a href="{{url_add}}" class="btn btn-primary shadow-sm">
                <i class="fa fa-plus-circle me-1" aria-hidden="true"></i> {{str_add}}
            </a>
        </div>
    </div>
    <div class="collapse w-100" id="ph-trades-hint">
        <div class="alert alert-info border-info mb-0 mt-3 small py-2 shadow-sm d-flex align-items-start">
            <i class="fa fa-lightbulb-o fa-lg me-2 mt-1 text-warning" aria-hidden="true"></i>
            <div>{{summary_hint}}</div>
        </div>
    </div>
</div>

<div class="row">
    {{#has_trades}}
        {{#trades}}
        <div class="col-lg-6 col-12 mb-4 d-flex justify-content-center">
            <div class="card ph-trade-widget-card shadow-sm h-100 w-100" role="group" aria-label="{{name}}">

                {{! TRADE HEADER }}
                <div class="card-header bg-light d-flex flex-wrap justify-content-between align-items-center border-bottom py-2">
                    <div class="d-flex align-items-center mb-2 mb-md-0">
                        {{#is_centralized}}
                            <span class="badge bg-primary text-white shadow-sm">{{str_shop}}</span>
                        {{/is_centralized}}
                        {{^is_centralized}}
                            <span class="badge bg-dark text-white shadow-sm">{{str_hidden}}</span>
                        {{/is_centralized}}
                        {{#is_onetime}}
                            <span class="badge bg-warning text-dark shadow-sm ms-1">{{str_onetime}}</span>
                        {{/is_onetime}}
                        {{^is_onetime}}
                            <span class="badge bg-success text-white shadow-sm ms-1"><i class="fa fa-refresh" aria-hidden="true"></i> {{str_unlimited}}</span>
                        {{/is_onetime}}
                        <span class="fw-bold ms-2 text-dark">{{name}}</span>
                    </div>
                    <div class="d-flex gap-1">
                        <a href="{{url_edit}}" class="btn btn-sm btn-primary shadow-sm" aria-label="{{str_edit}} {{name}}">
                            <i class="fa fa-pencil" aria-hidden="true"></i> <span class="d-none d-xl-inline ms-1">{{str_edit}}</span>
                        </a>
                        <a href="{{url_delete}}" class="btn btn-sm btn-danger shadow-sm js-delete-btn"
                           data-confirm-msg="{{confirm_msg}}" aria-label="{{str_delete}} {{name}}">
                            <i class="fa fa-trash" aria-hidden="true"></i> <span class="d-none d-xl-inline ms-1">{{str_delete}}</span>
                        </a>
                    </div>
                </div>

                {{! TRADE BODY (Identical to student view) }}
                <div class="card-body p-3 d-flex flex-column">
                    <div class="row align-items-center flex-grow-1">
                        <div class="col-5 text-center px-1">
                            <div class="text-danger small fw-bold text-uppercase mb-2 ph-trade-label">
                                <i class="fa fa-minus-circle me-1" aria-hidden="true"></i>{{str_pay}}
                            </div>
                            <div class="d-flex flex-column gap-2 align-items-center">
                                {{#requirements}}
                                <div class="badge bg-white text-dark border text-wrap d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                    <div class="me-2 flex-shrink-0 bg-light border rounded ph-trade-icon-box">
                                        {{#is_image}}
                                            <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain p-1">
                                        {{/is_image}}
                                        {{^is_image}}
                                            <span class="fs-4" aria-hidden="true">{{image_content}}</span>
                                        {{/is_image}}
                                    </div>
                                    <div class="text-break lh-sm ph-min-w-0">
                                        <span class="fw-bold fs-6">{{qty}}x</span>
                                        <span class="fw-normal">{{name}}</span>
                                    </div>
                                </div>
                                {{/requirements}}
                            </div>
                        </div>

                        <div class="col-2 text-center text-muted px-0">
                            <i class="fa fa-arrow-right fs-5" aria-hidden="true"></i>
                        </div>

                        <div class="col-5 text-center px-1">
                            <div class="text-success small fw-bold text-uppercase mb-2 ph-trade-label">
                                <i class="fa fa-plus-circle me-1" aria-hidden="true"></i>{{str_receive}}
                            </div>
                            <div class="d-flex flex-column gap-2 align-items-center">
                                {{#rewards}}
                                <div class="badge bg-white text-dark border border-success text-wrap d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                    <div class="me-2 flex-shrink-0 success-bg border border-success rounded ph-trade-icon-box">
                                        {{#is_image}}
                                            <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain p-1">
                                        {{/is_image}}
                                        {{^is_image}}
                                            <span class="fs-4" aria-hidden="true">{{image_content}}</span>
                                        {{/is_image}}
                                    </div>
                                    <div class="text-break lh-sm ph-min-w-0">
                                        <span class="fw-bold fs-6">{{qty}}x</span>
                                        <span class="fw-normal">{{name}}</span>
                                    </div>
                                </div>
                                {{/rewards}}
                            </div>
                        </div>
                    </div>
                </div>

                {{! FOOTER (SHORTCODE) }}
                <div class="card-footer bg-light border-top p-2">
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control font-monospace text-center text-muted bg-white border-end-0"
                               value="{{shortcode}}" readonly id="code_{{id}}">
                        <button class="btn btn-outline-secondary" type="button"
                                data-action="copytoclipboard"
                                data-clipboard-target="#code_{{id}}">
                            <i class="fa fa-copy me-1" aria-hidden="true"></i> {{str_copy}}
                        </button>
                    </div>
                </div>

            </div>
        </div>
        {{/trades}}
    {{/has_trades}}

    {{^has_trades}}
        <div class="col-12 text-center py-5 text-muted">
            <div class="ph-empty-icon-lg" aria-hidden="true">⚖️</div>
            <p class="mt-3">{{str_empty}}</p>
        </div>
    {{/has_trades}}
</div>
