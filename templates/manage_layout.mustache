{{!
    @template block_playerhud/manage_layout
    @package block_playerhud
    @copyright 2026 Jean Lúcio
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_title": "Game Master Panel",
        "url_student_area": "#",
        "str_student_area": "Student Area",
        "url_help": "#",
        "str_help": "Help",
        "url_course": "#",
        "str_back_course": "Back to Course",
        "str_wizard_open": "Generate Gamification",
        "wizard_show_empty_banner": true,
        "str_wizard_empty_title": "Start this course's gamification",
        "str_wizard_empty_desc": "There are no items or quests yet. Let AI build the basics for you.",
        "str_wizard_empty_btn": "Generate Gamification",
        "modal_wizard_html": "",
        "tabs": [
            { "active": true, "url": "#", "text": "Items", "icon": "<i class='fa fa-cube'></i>" },
            { "active": false, "url": "#", "text": "Settings", "icon": "<i class='fa fa-cog'></i>" }
        ],
        "content_html": "<p>Page content goes here...</p>"
    }
}}
<div class="container-fluid p-0 animate__animated animate__fadeIn">

    {{! Header }}
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="m-0">{{str_title}}</h2>
        <div class="d-flex">
            <button type="button" class="btn btn-primary shadow-sm fw-bold me-2" id="ph-wizard-open-btn">
                <i class="fa fa-magic me-1" aria-hidden="true"></i> {{str_wizard_open}}
            </button>
            <a href="{{url_student_area}}" class="btn btn-outline-primary shadow-sm fw-bold me-2">
                <i class="fa fa-graduation-cap me-1" aria-hidden="true"></i> {{str_student_area}}
            </a>
            <a href="{{url_help}}" class="btn btn-outline-info shadow-sm me-2">
                <i class="fa fa-question-circle me-1" aria-hidden="true"></i> {{str_help}}
            </a>
            <a href="{{url_course}}" class="btn btn-outline-secondary shadow-sm">
                 <i class="fa fa-arrow-left me-1" aria-hidden="true"></i> {{str_back_course}}
            </a>
        </div>
    </div>

    {{#wizard_show_empty_banner}}
    <div class="alert alert-primary d-flex justify-content-between align-items-center mb-4" role="status">
        <div>
            <strong>{{str_wizard_empty_title}}</strong>
            <div class="ph-text-xs">{{str_wizard_empty_desc}}</div>
        </div>
        <button type="button" class="btn btn-primary fw-bold ph-wizard-open-btn-banner">
            <i class="fa fa-magic me-1" aria-hidden="true"></i> {{str_wizard_empty_btn}}
        </button>
    </div>
    {{/wizard_show_empty_banner}}

    {{! Navigation Tabs }}
    <ul class="nav nav-tabs mb-4" id="ph-manage-tabs">
        {{#tabs}}
        <li class="nav-item">
            <a class="nav-link {{#active}}active{{/active}}" href="{{url}}">
                <span aria-hidden="true" class="me-2">{{icon}}</span> {{text}}
            </a>
        </li>
        {{/tabs}}
    </ul>

    {{! Main Content Area }}
    <div class="ph-manage-content">
        {{{content_html}}}
    </div>

</div>

{{{modal_wizard_html}}}
