{{!
    @template block_playerhud/tab_shop

    Shop tab output template for PlayerHUD.
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_warning": "Warning: items bought do not give XP.",
        "has_trades": true,
        "str_empty": "No trades available.",
        "str_pay": "You pay",
        "str_receive": "You receive",
        "str_redeemed": "Already bought",
        "str_perform": "Trade",
        "trades": [
            {
                "id": 1,
                "name": "Trade 1",
                "is_completed": false,
                "action_url": "#",
                "requirements": [
                    { "qty": 3, "name": "Wood", "is_image": false, "image_content": "🪵" }
                ],
                "rewards": [
                    { "qty": 1, "name": "Sword", "is_image": false, "image_content": "🗡️" }
                ]
            }
        ]
    }
}}
<div class="block_playerhud container-fluid p-0 animate__animated animate__fadeIn">

    <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        <div>{{{str_warning}}}</div>
    </div>

    <div class="row">
        {{#has_trades}}
            {{#trades}}
            <div class="col-lg-6 col-12 mb-4 d-flex justify-content-center">
                <div class="card ph-trade-widget-card shadow-sm h-100 w-100">
                    <div class="card-header bg-light border-bottom text-center py-2">
                        <h6 class="mb-0 fw-bold text-dark">
                            <i class="fa fa-balance-scale me-1 text-primary" aria-hidden="true"></i> {{name}}
                        </h6>
                    </div>
                    <div class="card-body p-3 d-flex flex-column">

                        <div class="row align-items-center flex-grow-1">
                            <div class="col-5 text-center px-1">
                                <div class="text-danger small fw-bold text-uppercase mb-2 ph-trade-label">
                                    <i class="fa fa-minus-circle me-1" aria-hidden="true"></i>{{str_pay}}
                                </div>
                                <div class="d-flex flex-column gap-2 align-items-center">
                                    {{#requirements}}
                                    <div class="badge bg-white text-dark border text-wrap d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                        <div class="me-2 flex-shrink-0 ph-trade-item-icon rounded-2">
                                            {{#is_image}}
                                                <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain rounded-2">
                                            {{/is_image}}
                                            {{^is_image}}
                                                <span class="ph-emoji-sm" aria-hidden="true">{{image_content}}</span>
                                            {{/is_image}}
                                        </div>
                                        <div class="ph-min-w-0 d-flex flex-column justify-content-center py-1 w-100">
                                            <div class="text-break lh-sm mb-1">
                                                <span class="fw-bold fs-6">{{qty}}x</span>
                                                <span class="fw-normal">{{name}}</span>
                                            </div>
                                            <small class="fw-bold {{qty_class}} ph-text-xs lh-1 text-wrap w-100">
                                                {{#str}} trade_you_have, block_playerhud, {{user_qty}} {{/str}}
                                            </small>
                                        </div>
                                    </div>
                                    {{/requirements}}
                                </div>
                            </div>

                            <div class="col-2 text-center text-muted px-0">
                                <i class="fa fa-arrow-right fs-5" aria-hidden="true"></i>
                            </div>

                            <div class="col-5 text-center px-1">
                                <div class="text-success small fw-bold text-uppercase mb-2 ph-trade-label">
                                    <i class="fa fa-plus-circle me-1" aria-hidden="true"></i>{{str_receive}}
                                </div>
                                <div class="d-flex flex-column gap-2 align-items-center">
                                    {{#rewards}}
                                    <div class="badge bg-white text-dark border border-success text-wrap d-flex align-items-center p-1 pe-2 shadow-sm w-100 text-start" title="{{name}}">
                                        <div class="me-2 flex-shrink-0 ph-trade-item-icon success-bg rounded-2">
                                            {{#is_image}}
                                                <img src="{{image_url}}" alt="" class="img-fluid w-100 h-100 object-fit-contain rounded-2">
                                            {{/is_image}}
                                            {{^is_image}}
                                                <span class="ph-emoji-sm" aria-hidden="true">{{image_content}}</span>
                                            {{/is_image}}
                                        </div>
                                        <div class="text-break lh-sm ph-min-w-0">
                                            <span class="fw-bold fs-6">{{qty}}x</span>
                                            <span class="fw-normal">{{name}}</span>
                                        </div>
                                    </div>
                                    {{/rewards}}
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-3 pt-3 border-top">
                            {{#is_completed}}
                                <button class="btn btn-secondary w-100 fw-bold shadow-sm rounded-3" disabled>
                                    <i class="fa fa-check me-1" aria-hidden="true"></i> {{str_redeemed}}
                                </button>
                            {{/is_completed}}
                            {{^is_completed}}
                                {{#can_afford}}
                                <a href="{{action_url}}" class="btn btn-success w-100 fw-bold shadow-sm rounded-3">
                                    <i class="fa fa-exchange me-1" aria-hidden="true"></i> {{str_perform}}
                                </a>
                                {{/can_afford}}
                                {{^can_afford}}
                                <button class="btn btn-outline-secondary w-100 fw-bold shadow-sm rounded-3" disabled>
                                    <i class="fa fa-lock me-1" aria-hidden="true"></i> {{str_missing_items}}
                                </button>
                                {{/can_afford}}
                            {{/is_completed}}
                        </div>
                    </div>
                </div>
            </div>
            {{/trades}}
        {{/has_trades}}

        {{^has_trades}}
            <div class="col-12 text-center py-5 text-muted">
                <div class="ph-icon-empty" aria-hidden="true">🏪</div>
                <p class="mt-3">{{str_empty}}</p>
            </div>
        {{/has_trades}}
    </div>
</div>
