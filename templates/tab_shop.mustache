{{!
    @template block_playerhud/tab_shop

    Shop tab output template for PlayerHUD.
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_warning": "Warning: items bought do not give XP.",
        "has_trades": true,
        "str_empty": "No trades available.",
        "str_pay": "You pay",
        "str_receive": "You receive",
        "str_redeemed": "Already bought",
        "str_perform": "Trade",
        "trades": [
            {
                "id": 1,
                "name": "Trade 1",
                "is_completed": false,
                "action_url": "#",
                "requirements": [
                    { "qty": 3, "name": "Wood", "is_image": false, "image_content": "🪵" }
                ],
                "rewards": [
                    { "qty": 1, "name": "Sword", "is_image": false, "image_content": "🗡️" }
                ]
            }
        ]
    }
}}
<div class="container-fluid p-0 animate__animated animate__fadeIn">

    <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center">
        <i class="fa fa-info-circle me-2" aria-hidden="true"></i>
        <div>{{{str_warning}}}</div>
    </div>

    <div class="row">
        {{#has_trades}}
            {{#trades}}
            <div class="col-lg-6 col-12 mb-4">
                <div class="ph-trade-card h-100 d-flex flex-column border rounded shadow-sm bg-white">
                    <div class="ph-trade-body flex-grow-1 p-3">

                        {{! STUDENT PAYS SECTION }}
                        <div class="ph-trade-section ph-trade-req mb-3">
                            <small class="text-uppercase text-muted fw-bold mb-2 d-block ph-text-xs">
                                {{str_pay}}
                            </small>
                            {{#requirements}}
                            <div class="d-flex align-items-center mb-1">
                                <div class="me-2 text-center" style="width: 30px;">
                                    {{#is_image}}
                                        <img src="{{image_url}}" alt="" style="width:30px;height:30px;object-fit:contain;">
                                    {{/is_image}}
                                    {{^is_image}}
                                        <span class="fs-4 lh-1" aria-hidden="true">{{image_content}}</span>
                                    {{/is_image}}
                                </div>
                                <div class="text-muted small">{{qty}}x {{name}}</div>
                            </div>
                            {{/requirements}}
                        </div>

                        <div class="ph-trade-arrow text-center text-muted mb-3 opacity-50">
                            <i class="fa fa-arrow-down" aria-hidden="true"></i>
                        </div>

                        {{! STUDENT RECEIVES SECTION }}
                        <div class="ph-trade-section ph-trade-give">
                            <small class="text-uppercase text-muted fw-bold mb-2 d-block ph-text-xs">
                                {{str_receive}}
                            </small>
                            {{#rewards}}
                            <div class="d-flex align-items-center mb-1 text-dark">
                                <div class="me-2 text-center" style="width: 30px;">
                                    {{#is_image}}
                                        <img src="{{image_url}}" alt="" style="width:30px;height:30px;object-fit:contain;">
                                    {{/is_image}}
                                    {{^is_image}}
                                        <span class="fs-4 lh-1" aria-hidden="true">{{image_content}}</span>
                                    {{/is_image}}
                                </div>
                                <div class="fw-bold small">{{qty}}x {{name}}</div>
                            </div>
                            {{/rewards}}
                        </div>

                    </div>

                    {{! ACTION BUTTON }}
                    <div class="card-footer bg-white border-top-0 pt-0 text-center pb-3">
                        {{#is_completed}}
                            <button class="btn btn-secondary w-100 fw-bold" disabled>
                                <i class="fa fa-check me-1" aria-hidden="true"></i> {{str_redeemed}}
                            </button>
                        {{/is_completed}}
                        {{^is_completed}}
                            <a href="{{action_url}}" class="btn btn-success w-100 shadow-sm fw-bold">
                                <i class="fa fa-exchange me-1" aria-hidden="true"></i> {{str_perform}}
                            </a>
                        {{/is_completed}}
                    </div>
                </div>
            </div>
            {{/trades}}
        {{/has_trades}}

        {{^has_trades}}
            <div class="col-12 text-center py-5 text-muted">
                <div style="font-size: 3rem; opacity: 0.3;" aria-hidden="true">🏪</div>
                <p class="mt-3">{{str_empty}}</p>
            </div>
        {{/has_trades}}
    </div>
</div>
