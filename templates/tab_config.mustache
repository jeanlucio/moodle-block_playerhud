{{!
    @template block_playerhud/tab_config
    @package block_playerhud
    @copyright 2026 Jean Lúcio
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "alert_border_class": "border-info",
        "total_items_xp": "500",
        "xp_ceiling": "2000",
        "alert_class": "alert-info",
        "alert_icon": "fa-info-circle",
        "balance_message": "Game economy is balanced.",
        "widget_code_tip_html": "Tip: Paste this code...",
        "action_url": "#",
        "sesskey": "12345",
        "val_gemini": "",
        "val_groq": "",
        "val_openai": "",
        "val_openai_url": "",
        "val_openai_model": "",
        "placeholder_openai_url": "https://api.openai.com/v1/chat/completions",
        "placeholder_openai_model": "gpt-4o-mini"
    }
}}
<div class="row">
    {{! --- Balance Card --- }}
    <div class="col-12 mb-4">
        <div class="card shadow-sm {{alert_border_class}}">
            <div class="card-header bg-white fw-bold">
                <i class="fa fa-balance-scale me-2" aria-hidden="true"></i> {{#str}} game_balance, block_playerhud {{/str}}
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3 text-center border-end">
                        <h3 class="m-0 text-primary">{{total_items_xp}}</h3>
                        <small class="text-muted text-uppercase ph-text-xs">{{#str}} total_items_xp, block_playerhud {{/str}}</small>
                    </div>
                    <div class="col-md-3 text-center border-end">
                        <h3 class="m-0 text-dark">{{xp_ceiling}}</h3>
                        <small class="text-muted text-uppercase ph-text-xs">{{#str}} xp_required_max, block_playerhud {{/str}}</small>
                    </div>
                    <div class="col-md-6">
                        <div class="alert {{alert_class}} m-0 d-flex align-items-center">
                            <i class="fa {{alert_icon}} fa-2x me-3" aria-hidden="true"></i>
                            <div>{{{balance_message}}}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! --- Widget Card (Mobile/Embed) --- }}
    <div class="col-md-6">
        <div class="card border-primary mb-4 h-100 shadow-sm">
            <div class="card-header bg-primary text-white fw-bold d-flex align-items-center">
                <i class="fa fa-mobile fa-lg me-2" aria-hidden="true"></i>
                {{#str}} widget_code_title, block_playerhud {{/str}}
            </div>
            <div class="card-body">
                <p class="card-text">{{#str}} widget_code_desc, block_playerhud {{/str}}</p>

                <div class="input-group input-group-lg mb-3 mt-4">
                    <span class="input-group-text bg-light text-muted border-end-0">
                        <i class="fa fa-code" aria-hidden="true"></i>
                    </span>
                    <input type="text" class="form-control font-monospace text-center ph-code-input border-start-0"
                           value="[PLAYERHUD_WIDGET]" readonly id="widgetCode"
                           aria-label="{{#str}} widget_code_title, block_playerhud {{/str}}">

                    <button class="btn btn-dark" type="button"
                            data-action="copytoclipboard"
                            data-clipboard-target="#widgetCode">
                        <i class="fa fa-copy me-1" aria-hidden="true"></i> {{#str}} gen_copy, block_playerhud {{/str}}
                    </button>
                </div>

                <div class="alert alert-warning d-flex align-items-start mt-3 mb-0">
                    <i class="fa fa-lightbulb-o fa-lg me-3 mt-1" aria-hidden="true"></i>
                    <div class="small lh-sm">
                        {{{widget_code_tip_html}}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! --- API Settings Card --- }}
    <div class="col-md-6">
        <div class="card border-dark mb-4 h-100 shadow-sm">
            <div class="card-header bg-dark text-white fw-bold">
                <i class="fa fa-key me-2" aria-hidden="true"></i> {{#str}} api_settings_title, block_playerhud {{/str}}
            </div>
            <div class="card-body">
                <p class="card-text small">{{#str}} api_settings_desc, block_playerhud {{/str}}</p>

                <form action="{{action_url}}" method="post">
                    <input type="hidden" name="sesskey" value="{{sesskey}}">

                    <div class="mb-3">
                        <label class="fw-bold form-label" for="gemini_key">
                            <span class="badge bg-dark me-1" aria-hidden="true">1°</span>
                            {{#str}} gemini_apikey, block_playerhud {{/str}}
                        </label>
                        <div class="input-group ph-key-input-group">
                            <span class="input-group-text"><i class="fa fa-google" aria-hidden="true"></i></span>
                            <input type="password" class="form-control" name="gemini_key" id="gemini_key"
                                   value="{{val_gemini}}" placeholder="{{#str}} api_key_placeholder, block_playerhud {{/str}}"
                                   autocomplete="new-password">
                            <button type="button" class="btn btn-outline-secondary ph-toggle-key"
                                    data-target="gemini_key"
                                    aria-label="{{#str}} show_hide_key, block_playerhud {{/str}}"
                                    aria-pressed="false">
                                <span aria-hidden="true">&#128065;</span>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold form-label" for="groq_key">
                            <span class="badge bg-dark me-1" aria-hidden="true">2°</span>
                            {{#str}} groq_apikey, block_playerhud {{/str}}
                        </label>
                        <div class="input-group ph-key-input-group">
                            <span class="input-group-text"><i class="fa fa-bolt" aria-hidden="true"></i></span>
                            <input type="password" class="form-control" name="groq_key" id="groq_key"
                                   value="{{val_groq}}" placeholder="{{#str}} api_key_placeholder, block_playerhud {{/str}}"
                                   autocomplete="new-password">
                            <button type="button" class="btn btn-outline-secondary ph-toggle-key"
                                    data-target="groq_key"
                                    aria-label="{{#str}} show_hide_key, block_playerhud {{/str}}"
                                    aria-pressed="false">
                                <span aria-hidden="true">&#128065;</span>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold form-label" for="openai_key">
                            <span class="badge bg-dark me-1" aria-hidden="true">3°</span>
                            {{#str}} custom_ai_apikey, block_playerhud {{/str}}
                        </label>
                        <div class="input-group ph-key-input-group">
                            <span class="input-group-text"><i class="fa fa-plug" aria-hidden="true"></i></span>
                            <input type="password" class="form-control" name="openai_key" id="openai_key"
                                   value="{{val_openai}}" placeholder="{{#str}} api_key_placeholder, block_playerhud {{/str}}"
                                   autocomplete="new-password">
                            <button type="button" class="btn btn-outline-secondary ph-toggle-key"
                                    data-target="openai_key"
                                    aria-label="{{#str}} show_hide_key, block_playerhud {{/str}}"
                                    aria-pressed="false">
                                <span aria-hidden="true">&#128065;</span>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <a class="small text-decoration-none d-block mb-2"
                           data-bs-toggle="collapse" data-toggle="collapse"
                           href="#customai-advanced" role="button" aria-expanded="false" aria-controls="customai-advanced">
                            <i class="fa fa-caret-right me-1" aria-hidden="true"></i>
                            {{#str}} custom_ai_advanced, block_playerhud {{/str}}
                        </a>
                        <div class="collapse" id="customai-advanced">
                            <p class="small mb-2">{{#str}} custom_ai_advanced_hint, block_playerhud {{/str}}</p>
                            <div class="mb-2">
                                <label class="form-label small fw-semibold" for="openai_url">
                                    {{#str}} custom_ai_baseurl, block_playerhud {{/str}}
                                </label>
                                <input type="url" class="form-control form-control-sm" name="openai_url" id="openai_url"
                                       value="{{val_openai_url}}" placeholder="{{placeholder_openai_url}}">
                            </div>
                            <div>
                                <label class="form-label small fw-semibold" for="openai_model">
                                    {{#str}} custom_ai_model, block_playerhud {{/str}}
                                </label>
                                <input type="text" class="form-control form-control-sm" name="openai_model" id="openai_model"
                                       value="{{val_openai_model}}" placeholder="{{placeholder_openai_model}}">
                            </div>
                        </div>
                    </div>

                    <hr>
                    <button type="submit" class="btn btn-success w-100 shadow-sm">
                        <i class="fa fa-save me-1" aria-hidden="true"></i> {{#str}} save_keys, block_playerhud {{/str}}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{{#js}}
require(['core/copy_to_clipboard', 'block_playerhud/tab_config'], function(Clipboard, TabConfig) {
    TabConfig.init();
});
{{/js}}
