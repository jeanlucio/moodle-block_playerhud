{{!
    @template block_playerhud/modal_wizard
    @package block_playerhud
    @copyright 2026 Jean Lúcio
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "instanceid": 5,
        "courseid": 2,
        "tone_options": [
            {"value": "scifi", "label": "Ficção Científica"},
            {"value": "fantasy", "label": "Fantasia Medieval"}
        ],
        "size_options": [
            {"value": "short", "label": "Curta (~5 itens)"},
            {"value": "medium", "label": "Média (~10 itens)"},
            {"value": "long", "label": "Longa (~15 itens)"}
        ],
        "has_playergroup": false,
        "has_latepenalty": true,
        "levels_at_default": true,
        "gen_items": false,
        "gen_missions": false,
        "gen_playercoin": true,
        "gen_avatars": false,
        "gen_trade": false,
        "gen_pill": false,
        "gen_secret": false,
        "gen_latepenalty": false,
        "gen_progressitem": false,
        "gen_rpg": false,
        "gen_ranking": true
    }
}}
<div class="modal fade" id="ph-wizard-modal" tabindex="-1" aria-labelledby="ph-wizard-modal-label" aria-hidden="true"
     data-instanceid="{{instanceid}}" data-courseid="{{courseid}}">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title fw-bold m-0" id="ph-wizard-modal-label">
            <i class="fa fa-magic me-2" aria-hidden="true"></i>{{#str}} wizard_title, block_playerhud {{/str}}
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" data-dismiss="modal"
                aria-label="{{#str}} close, block_playerhud {{/str}}">
            <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="row align-items-start">
        <div class="col-lg-7">
        <form id="ph-wizard-form">
            <div class="row g-3 mb-3">
                <div class="col-12 col-md-4">
                    <label for="ph-wizard-theme" class="form-label fw-bold">
                        {{#str}} wizard_theme_label, block_playerhud {{/str}}
                    </label>
                    <input type="text" class="form-control" id="ph-wizard-theme"
                           placeholder="{{#str}} wizard_theme_placeholder, block_playerhud {{/str}}">
                </div>
                <div class="col-6 col-md-4">
                    <label for="ph-wizard-tone" class="form-label fw-bold">
                        {{#str}} wizard_tone_label, block_playerhud {{/str}}
                    </label>
                    <select class="form-control form-select" id="ph-wizard-tone">
                        {{#tone_options}}
                        <option value="{{value}}">{{label}}</option>
                        {{/tone_options}}
                    </select>
                </div>
                <div class="col-6 col-md-4">
                    <div class="d-flex align-items-center gap-1 mb-2">
                        <label for="ph-wizard-size" class="form-label fw-bold mb-0">
                            {{#str}} wizard_size_label, block_playerhud {{/str}}
                        </label>
                        <button type="button"
                                class="btn btn-link p-0 ph-wizard-info-btn js-ph-wizard-info"
                                aria-label="{{#str}} wizard_size_help_label, block_playerhud {{/str}}"
                                title="{{#str}} wizard_size_help, block_playerhud {{/str}}">
                            <i class="fa fa-info-circle" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <select class="form-control form-select w-auto" id="ph-wizard-size">
                            {{#size_options}}
                            <option value="{{value}}">{{label}}</option>
                            {{/size_options}}
                        </select>
                        <div class="form-check mb-0 d-flex align-items-center gap-1">
                            <input type="checkbox" class="form-check-input mt-0" id="ph-wizard-apply-levels"
                                   {{#levels_at_default}}checked{{/levels_at_default}}>
                            <label class="form-check-label ph-text-sm mb-0 ph-wizard-levels-label"
                                   for="ph-wizard-apply-levels">
                                {{#str}} wizard_levels_checkbox_label, block_playerhud {{/str}}
                            </label>
                            <button type="button"
                                    class="btn btn-link p-0 ph-wizard-info-btn js-ph-wizard-info"
                                    aria-label="{{#str}} wizard_levels_help_label, block_playerhud {{/str}}"
                                    title="{{#str}} wizard_levels_help, block_playerhud {{/str}}">
                                <i class="fa fa-info-circle" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-2 mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                <span class="fw-bold text-uppercase ph-text-xs text-muted">
                    {{#str}} wizard_section_economy, block_playerhud {{/str}}
                </span>
                <div class="form-check mb-0">
                    <input type="checkbox" class="form-check-input" id="ph-wizard-select-all">
                    <label class="form-check-label ph-text-xs" for="ph-wizard-select-all">
                        {{#str}} wizard_select_all_label, block_playerhud {{/str}}
                    </label>
                </div>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-2 mb-3" id="ph-wizard-section-economy">
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <span class="badge ph-wizard-ai-badge">
                            <i class="fa fa-robot me-1" aria-hidden="true"></i>{{#str}} wizard_ai_badge_label, block_playerhud {{/str}}
                        </span>
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-items"
                                   data-drives="2" {{#gen_items}}disabled{{/gen_items}}{{^gen_items}}checked{{/gen_items}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-items">
                                <i class="fa fa-cube ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_items_ai, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_items_desc, block_playerhud {{/str}}
                        </small>
                        {{^gen_items}}
                        <div class="form-check mt-2 ph-wizard-distribute-check">
                            <input type="checkbox" class="form-check-input" id="ph-wizard-distribute-items" checked>
                            <label class="form-check-label ph-text-sm" for="ph-wizard-distribute-items">
                                {{#str}} wizard_distribute_checkbox_label, block_playerhud {{/str}}
                            </label>
                        </div>
                        {{/gen_items}}
                        {{#gen_items}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_items}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-playercoin"
                                   data-drives="8,1" {{#gen_playercoin}}disabled{{/gen_playercoin}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-playercoin">
                                <i class="fa fa-coins ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_playercoin, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_playercoin_desc, block_playerhud {{/str}}
                        </small>
                        {{^gen_playercoin}}
                        <div class="form-check mt-2 ph-wizard-distribute-check">
                            <input type="checkbox" class="form-check-input" id="ph-wizard-distribute-playercoin" checked>
                            <label class="form-check-label ph-text-sm" for="ph-wizard-distribute-playercoin">
                                {{#str}} wizard_distribute_playercoin_checkbox_label, block_playerhud {{/str}}
                            </label>
                        </div>
                        {{/gen_playercoin}}
                        {{#gen_playercoin}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_playercoin}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-avatars"
                                   data-drives="8,2" {{#gen_avatars}}disabled{{/gen_avatars}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-avatars">
                                <i class="fa fa-theater-masks ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_avatars, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_avatars_desc, block_playerhud {{/str}}
                        </small>
                        {{#gen_avatars}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_avatars}}
                        <div class="mt-3 pt-2 border-top" id="ph-wizard-card-trade">
                            <div class="form-check mb-0">
                                <input type="checkbox" class="form-check-input" id="ph-wizard-module-trade"
                                       data-drives="3,5" disabled>
                                <label class="form-check-label fw-bold" for="ph-wizard-module-trade">
                                    <i class="fa fa-shopping-cart ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                    {{#str}} wizard_module_trade, block_playerhud {{/str}}
                                </label>
                            </div>
                            <small class="text-muted d-block mt-1">
                                {{#str}} wizard_module_trade_desc, block_playerhud {{/str}}
                            </small>
                            {{^gen_trade}}
                            <small class="d-block mt-2 fw-bold ph-wizard-trade-requirement"
                                   id="ph-wizard-trade-requirement">
                                {{#str}} wizard_module_trade_requirement_unmet, block_playerhud {{/str}}
                            </small>
                            {{/gen_trade}}
                            {{#gen_trade}}
                            <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                                <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                            </small>
                            {{/gen_trade}}
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-2 mt-2">
                <span class="fw-bold text-uppercase ph-text-xs text-muted">
                    {{#str}} wizard_section_collectibles, block_playerhud {{/str}}
                </span>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-2 mb-3">
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-progressitem"
                                   {{#gen_progressitem}}disabled{{/gen_progressitem}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-progressitem">
                                <i class="fa fa-key ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_progress_item, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_progress_item_desc, block_playerhud {{/str}}
                        </small>
                        {{^gen_progressitem}}
                        <div class="form-check mt-2 ph-wizard-distribute-check">
                            <input type="checkbox" class="form-check-input" id="ph-wizard-distribute-progressitem"
                                   checked>
                            <label class="form-check-label ph-text-sm" for="ph-wizard-distribute-progressitem">
                                {{#str}} wizard_distribute_checkbox_label, block_playerhud {{/str}}
                            </label>
                        </div>
                        {{/gen_progressitem}}
                        {{#gen_progressitem}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_progressitem}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-pill"
                                   data-drives="6,7" {{#gen_pill}}disabled{{/gen_pill}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-pill">
                                <i class="fa fa-graduation-cap ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_pill, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_pill_desc, block_playerhud {{/str}}
                        </small>
                        {{^gen_pill}}
                        <div class="form-check mt-2 ph-wizard-distribute-check">
                            <input type="checkbox" class="form-check-input" id="ph-wizard-distribute-pill" checked>
                            <label class="form-check-label ph-text-sm" for="ph-wizard-distribute-pill">
                                {{#str}} wizard_distribute_checkbox_label, block_playerhud {{/str}}
                            </label>
                        </div>
                        {{/gen_pill}}
                        {{#gen_pill}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_pill}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-secret"
                                   data-drives="6,5" {{#gen_secret}}disabled{{/gen_secret}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-secret">
                                <i class="fa fa-question-circle ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_secret, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_secret_desc, block_playerhud {{/str}}
                        </small>
                        {{^gen_secret}}
                        <div class="form-check mt-2 ph-wizard-distribute-check">
                            <input type="checkbox" class="form-check-input" id="ph-wizard-distribute-secret" checked>
                            <label class="form-check-label ph-text-sm" for="ph-wizard-distribute-secret">
                                {{#str}} wizard_distribute_secret_checkbox_label, block_playerhud {{/str}}
                            </label>
                        </div>
                        {{/gen_secret}}
                        {{#gen_secret}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_secret}}
                    </div>
                </div>
                {{#has_latepenalty}}
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-latepenalty"
                                   data-drives="3" {{#gen_latepenalty}}disabled{{/gen_latepenalty}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-latepenalty">
                                <i class="fa fa-hourglass-half ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_latepenalty, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_latepenalty_desc, block_playerhud {{/str}}
                        </small>
                        {{#gen_latepenalty}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_latepenalty}}
                    </div>
                </div>
                {{/has_latepenalty}}
            </div>

            <div class="mb-2 mt-2">
                <span class="fw-bold text-uppercase ph-text-xs text-muted">
                    {{#str}} wizard_section_other, block_playerhud {{/str}}
                </span>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-2 mb-2">
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-missions"
                                   data-drives="7,1" {{#gen_missions}}disabled{{/gen_missions}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-missions">
                                <i class="fa fa-bullseye ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_missions, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_missions_desc, block_playerhud {{/str}}
                        </small>
                        {{#gen_missions}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_missions}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <span class="badge ph-wizard-ai-badge">
                            <i class="fa fa-robot me-1" aria-hidden="true"></i>{{#str}} wizard_ai_badge_label, block_playerhud {{/str}}
                        </span>
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-rpg"
                                   data-drives="2,3,6,7,8" {{#gen_rpg}}disabled{{/gen_rpg}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-rpg">
                                <i class="fa fa-book ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_rpg, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_rpg_desc, block_playerhud {{/str}}
                        </small>
                        {{#gen_rpg}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_generated, block_playerhud {{/str}}
                        </small>
                        {{/gen_rpg}}
                    </div>
                </div>
                <div class="col">
                    <div class="ph-wizard-mech-card bg-light border rounded p-3 h-100">
                        <div class="form-check mb-0">
                            <input type="checkbox" class="form-check-input ph-wizard-mech-module" id="ph-wizard-module-ranking"
                                   data-drives="4,1" {{#gen_ranking}}disabled checked{{/gen_ranking}}>
                            <label class="form-check-label fw-bold" for="ph-wizard-module-ranking">
                                <i class="fa fa-trophy ph-wizard-mech-icon me-1" aria-hidden="true"></i>
                                {{#str}} wizard_module_ranking, block_playerhud {{/str}}
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">
                            {{#str}} wizard_module_ranking_desc, block_playerhud {{/str}}
                        </small>
                        {{#gen_ranking}}
                        <small class="d-block mt-2 fw-bold ph-wizard-generated-note">
                            <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} wizard_module_active, block_playerhud {{/str}}
                        </small>
                        {{/gen_ranking}}
                    </div>
                </div>
            </div>

            <div class="alert alert-danger mt-3 ph-display-none" id="ph-wizard-error" role="alert"></div>
            <div class="alert alert-success mt-3 ph-display-none" id="ph-wizard-result" role="status"></div>
        </form>

        <div class="ph-display-none" id="ph-wizard-progress-view">
            <div class="alert alert-warning py-2 px-3 ph-text-xs ph-display-none" id="ph-wizard-progress-close-warning">
                {{#str}} wizard_progress_close_warning, block_playerhud {{/str}}
            </div>
            <div class="text-center mb-2">
                <strong id="ph-wizard-progress-label">&nbsp;</strong>
                <div class="text-muted ph-text-xs" id="ph-wizard-progress-substep"></div>
            </div>
            <div class="progress ph-wizard-progress-bar-wrap" role="progressbar" aria-valuemin="0" aria-valuemax="100"
                 id="ph-wizard-progress-bar-wrap">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                     id="ph-wizard-progress-bar" style="width: 0%"></div>
            </div>
            <div class="alert alert-info mt-3 py-2 px-3 ph-text-xs ph-display-none" id="ph-wizard-progress-slow-warning">
                {{#str}} wizard_progress_slow_warning, block_playerhud {{/str}}
            </div>

            <div class="text-center mt-3 ph-display-none" id="ph-wizard-huddy-carousel">
                <div class="d-flex align-items-center justify-content-center gap-2">
                    <button type="button" class="btn btn-link ph-wizard-huddy-nav" id="ph-wizard-huddy-prev"
                            aria-label="{{#str}} wizard_huddy_prev_label, block_playerhud {{/str}}">
                        <i class="fa fa-chevron-left" aria-hidden="true"></i>
                    </button>
                    <div class="ph-wizard-huddy-frame">
                        <img src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
                             alt="" width="160" height="160" class="ph-wizard-huddy-img" id="ph-wizard-huddy-img">
                        <div class="ph-wizard-huddy-pulse ph-display-none" id="ph-wizard-huddy-pulse" aria-hidden="true"></div>
                        <span class="ph-wizard-huddy-number ph-display-none" id="ph-wizard-huddy-number" aria-hidden="true">1</span>
                    </div>
                    <button type="button" class="btn btn-link ph-wizard-huddy-nav" id="ph-wizard-huddy-next"
