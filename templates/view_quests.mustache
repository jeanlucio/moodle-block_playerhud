{{!
    @template block_playerhud/view_quests

    Displays student quest cards with claim buttons (Grid layout).

    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_reward": "Rewards",
        "str_progress_label": "Completed",
        "quests": [
            {
                "id": 1,
                "name": "Reach Level 5",
                "description_html": "<p>Reach level 5 in the course.</p>",
                "image_todo": "📋",
                "image_done": "🏅",
                "type_label": "Reach Level",
                "is_activity": false,
                "reward_text": "50 XP",
                "has_reward": true,
                "is_claimed": false,
                "can_claim": true,
                "progress_pct": 80,
                "str_progress": "80%",
                "progress_label": "4 / 5",
                "activity_url": "",
                "url_claim": "#",
                "str_claim": "Claim Reward",
                "str_pending": "Pending",
                "str_claimed": "Completed",
                "str_go_activity": "Go to activity",
                "claimed_date": "19/01/26"
            }
        ]
    }
}}
<div class="block_playerhud playerhud-inventory-grid animate__animated animate__fadeIn">
    {{#quests}}
    <div class="playerhud-item-card card position-relative text-center
        {{#is_claimed}}ph-quest-card-claimed{{/is_claimed}}
        {{^is_claimed}}{{#can_claim}}ph-quest-card-ready{{/can_claim}}{{/is_claimed}}
        {{^is_claimed}}{{^can_claim}}ph-quest-card-pending{{/can_claim}}{{/is_claimed}}">

        <div class="card-body p-2 d-flex flex-column align-items-center h-100">
            {{! Quest icon. }}
            <div class="mb-1 text-center ph-card-icon-container flex-shrink-0">
                <div class="ph-modal-emoji ph-card-emoji" aria-hidden="true">
                    {{#is_claimed}}{{image_done}}{{/is_claimed}}
                    {{^is_claimed}}{{image_todo}}{{/is_claimed}}
                </div>
            </div>

            {{! Title }}
            <div class="fw-bold mb-1 ph-text-md w-100 lh-sm flex-shrink-0" title="{{name}}">{{name}}</div>

            {{! Description (Scrollable, Flex-grow, Accessible) }}
            {{#description_html}}
            <div class="small mb-2 w-100 ph-quest-desc-scroll text-break" tabindex="0" aria-label="{{name}} - {{#str}} description, block_playerhud {{/str}}">
                {{{description_html}}}
            </div>
            {{/description_html}}

            {{! Bottom Action Area }}
            <div class="mt-auto w-100 flex-shrink-0">
                {{#is_claimed}}
                    <div class="ph-quest-claimed-stamp w-100 py-1 rounded">
                        <div class="small fw-bold ph-text-gold-dark">
                            <i class="fa fa-check-circle me-1" aria-hidden="true"></i> {{str_claimed}}
                        </div>
                        <div class="ph-text-xs fw-bold ph-text-gold-dark mt-1">{{claimed_date}}</div>
                    </div>
                {{/is_claimed}}

                {{^is_claimed}}
                    {{#can_claim}}
                        <a href="{{url_claim}}" class="btn btn-success btn-sm w-100 fw-bold shadow-sm" aria-label="{{str_claim}}: {{name}}">
                            {{str_claim}}
                        </a>
                    {{/can_claim}}
                    {{^can_claim}}
                        <div class="progress ph-progress-container ph-progress-sm mb-2" aria-hidden="true">
                            <div class="progress-bar bg-info" style="width: {{progress_pct}}%;"></div>
                        </div>
                        <div class="text-center mb-1">
                            <small class="text-muted fw-bold" aria-hidden="true">{{progress_pct}}%</small>
                            <span class="visually-hidden">{{str_progress_label}}: {{progress_pct}}%</span>
                        </div>
                        {{#activity_url}}
                        <a href="{{activity_url}}" class="btn btn-outline-primary btn-sm w-100 fw-bold"
                           aria-label="{{str_go_activity}}: {{name}}">
                            <i class="fa fa-external-link me-1" aria-hidden="true"></i>{{str_go_activity}}
                        </a>
                        {{/activity_url}}
                        {{^activity_url}}
                        <div class="badge bg-light text-muted border w-100 py-1 shadow-sm">
                            <i class="fa fa-lock" aria-hidden="true"></i>
                            <span class="visually-hidden">{{str_pending}}</span>
                        </div>
                        {{/activity_url}}
                    {{/can_claim}}
                {{/is_claimed}}
            </div>
        </div>
    </div>
    {{/quests}}
</div>
