{{!
    @template block_playerhud/view_quests

    Displays student quest cards with claim buttons.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "str_reward": "Rewards",
        "str_progress_label": "Completed",
        "quests": [
            {
                "id": 1,
                "name": "Reach Level 5",
                "description_html": "<p>Reach level 5 in the course.</p>",
                "image_todo": "📋",
                "image_done": "🏅",
                "type_label": "Reach Level",
                "is_activity": false,
                "reward_text": "50 XP",
                "has_reward": true,
                "is_claimed": false,
                "can_claim": true,
                "progress_pct": 80,
                "str_progress": "80%",
                "progress_label": "4 / 5",
                "url_claim": "#",
                "str_claim": "Claim Reward",
                "str_pending": "Pending",
                "str_claimed": "Completed"
            }
        ]
    }
}}
<div class="block_playerhud">
    <div class="row g-3">
        {{#quests}}
        <div class="col-12 col-md-6">
            <div class="card h-100 ph-quest-card
                {{#is_claimed}}ph-quest-claimed{{/is_claimed}}
                {{^is_claimed}}{{#can_claim}}ph-quest-ready{{/can_claim}}{{/is_claimed}}">

                <div class="card-body">
                    {{! Icon + title }}
                    <div class="d-flex align-items-start mb-2">
                        <span class="ph-quest-icon me-2" aria-hidden="true">
                            {{#is_claimed}}{{image_done}}{{/is_claimed}}
                            {{^is_claimed}}{{image_todo}}{{/is_claimed}}
                        </span>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title mb-0 fw-bold">{{name}}</h5>
                                <span class="badge bg-secondary ms-2 flex-shrink-0">{{type_label}}</span>
                            </div>
                        </div>
                    </div>

                    {{! Description }}
                    {{#description_html}}
                    <div class="card-text text-muted small mb-2">{{{description_html}}}</div>
                    {{/description_html}}

                    {{! Reward }}
                    {{#has_reward}}
                    <p class="small mb-2">
                        <i class="fa fa-gift me-1 text-warning" aria-hidden="true"></i>
                        <strong>{{str_reward}}:</strong> {{reward_text}}
                    </p>
                    {{/has_reward}}

                    {{! Progress bar }}
                    <div class="mb-3">
                        <div class="progress" role="progressbar"
                             aria-valuenow="{{progress_pct}}"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            <div class="progress-bar
                                {{#is_claimed}}bg-success{{/is_claimed}}
                                {{^is_claimed}}{{#can_claim}}bg-primary{{/can_claim}}{{/is_claimed}}"
                                 style="width: {{progress_pct}}%">
                            </div>
                        </div>
                        <small class="text-muted">{{progress_label}}</small>
                        <span class="visually-hidden">{{str_progress_label}}: {{str_progress}}</span>
                    </div>
                </div>

                {{! Card footer: status / claim button }}
                <div class="card-footer bg-transparent border-top-0 pt-0">
                    {{#is_claimed}}
                    <span class="badge bg-success px-3 py-2">
                        <i class="fa fa-check me-1" aria-hidden="true"></i>
                        {{str_claimed}}
                    </span>
                    {{/is_claimed}}

                    {{^is_claimed}}
                    {{#can_claim}}
                    <a href="{{url_claim}}"
                       class="btn btn-success btn-sm"
                       aria-label="{{str_claim}}: {{name}}">
                        <i class="fa fa-trophy me-1" aria-hidden="true"></i>
                        {{str_claim}}
                    </a>
                    {{/can_claim}}
                    {{^can_claim}}
                    <span class="badge bg-light text-muted border px-3 py-2">
                        <i class="fa fa-clock-o me-1" aria-hidden="true"></i>
                        {{str_pending}}
                    </span>
                    {{/can_claim}}
                    {{/is_claimed}}
                </div>

            </div>
        </div>
        {{/quests}}
    </div>
</div>
