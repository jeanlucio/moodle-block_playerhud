{{!
    Scene list management page for a story chapter.

    @template   block_playerhud/manage_scenes
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "back_url": "/blocks/playerhud/manage.php?id=2&instanceid=3&tab=chapters",
        "str_back": "Back to chapters",
        "str_scene_editor": "Scene editor",
        "chapter_title": "Chapter 1",
        "new_scene_url": "/blocks/playerhud/edit_scene.php?courseid=2&instanceid=3&chapterid=1",
        "str_new": "Add scene",
        "has_scenes": true,
        "scenes": [
            {
                "id_label": "Scene #1",
                "is_start": true,
                "str_start_badge": "Start",
                "snippet": "Once upon a time...",
                "choice_count": 2,
                "str_choices": "choices",
                "url_edit": "/blocks/playerhud/edit_scene.php?courseid=2&instanceid=3&chapterid=1&nodeid=1",
                "str_edit": "Edit",
                "url_delete": "/blocks/playerhud/manage_scenes.php?action=delete_scene&nodeid=1",
                "str_delete": "Delete",
                "confirm_msg": "Are you sure?"
            }
        ],
        "str_empty": "No scenes yet.",
        "str_confirm_delete_title": "Confirm delete",
        "str_cancel": "Cancel",
        "str_close": "Close",
        "str_delete": "Delete"
    }
}}
<div>
    <a href="{{back_url}}" class="btn btn-outline-secondary btn-sm mb-3">
        &larr; {{str_back}}
    </a>
</div>

<h3>{{str_scene_editor}}: {{chapter_title}}</h3>

<a href="{{new_scene_url}}" class="btn btn-primary mb-3">
    <i class="fa fa-plus-circle" aria-hidden="true"></i> {{str_new}}
</a>

{{#has_scenes}}
<div class="list-group mt-3">
    {{#scenes}}
    <div class="list-group-item p-3 mb-2 border rounded shadow-sm">
        <div class="d-flex w-100 justify-content-between align-items-start">
            <div>
                <strong>{{id_label}}</strong>
                {{#is_start}}
                <span class="badge bg-success ms-2">{{str_start_badge}}</span>
                {{/is_start}}
                <p class="mb-1 text-muted small mt-1">{{snippet}}</p>
                <small class="text-muted">{{choice_count}} {{str_choices}}</small>
            </div>
            <div class="d-flex gap-2 ms-3">
                <a href="{{url_edit}}" class="btn btn-sm btn-outline-primary">
                    <i class="fa fa-pencil" aria-hidden="true"></i> {{str_edit}}
                </a>
                <button class="btn btn-sm btn-outline-danger"
                        data-action="delete-scene"
                        data-confirm-msg="{{confirm_msg}}"
                        data-delete-url="{{url_delete}}"
                        data-bs-toggle="modal"
                        data-bs-target="#ph-confirm-delete-scene"
                        data-toggle="modal"
                        data-target="#ph-confirm-delete-scene">
                    <i class="fa fa-trash" aria-hidden="true"></i> {{str_delete}}
                </button>
            </div>
        </div>
    </div>
    {{/scenes}}
</div>
{{/has_scenes}}
{{^has_scenes}}
<div class="alert alert-info mt-3" role="alert">{{str_empty}}</div>
{{/has_scenes}}

<div class="modal fade" id="ph-confirm-delete-scene" tabindex="-1"
         aria-labelledby="ph-confirm-delete-scene-label" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ph-confirm-delete-scene-label">{{str_confirm_delete_title}}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        data-dismiss="modal" aria-label="{{str_close}}">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="ph-delete-scene-msg"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal" data-dismiss="modal">{{str_cancel}}</button>
                <a id="ph-delete-scene-url" href="#"
                   class="btn btn-danger">{{str_delete}}</a>
            </div>
        </div>
    </div>
</div>
