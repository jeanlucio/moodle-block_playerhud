{{!
    @template block_playerhud/help_teacher

    Teacher contextual help page rendered as a Bootstrap 5 accordion.

    Example context (json):
    {
        "str_title": "Teacher Manual",
        "url_manage": "#",
        "str_back_manage": "Back to Game Master Panel",
        "url_course": "#",
        "str_back_course": "Back to Course",
        "sections": [
            {
                "id": "ph-help-overview",
                "target": "phHelpOverview",
                "title": "Getting Started",
                "content": "PlayerHUD adds a gamification layer to your course.",
                "open": true
            }
        ]
    }
}}
<div class="container-fluid p-0 animate__animated animate__fadeIn">

    {{! Header }}
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="m-0">
            <i class="fa fa-question-circle me-2 text-info" aria-hidden="true"></i>{{str_title}}
        </h2>
        <div class="d-flex">
            <a href="{{url_manage}}" class="btn btn-outline-primary shadow-sm fw-bold me-2">
                <i class="fa fa-cogs me-1" aria-hidden="true"></i> {{str_back_manage}}
            </a>
            <a href="{{url_course}}" class="btn btn-outline-secondary shadow-sm">
                <i class="fa fa-arrow-left me-1" aria-hidden="true"></i> {{str_back_course}}
            </a>
        </div>
    </div>

    {{! Accordion }}
    <div class="accordion shadow-sm" id="ph-help-accordion">
        {{#sections}}
        <div class="accordion-item">
            <h2 class="accordion-header" id="heading-{{id}}">
                <button
                    class="accordion-button{{^open}} collapsed{{/open}} fw-semibold"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#{{target}}"
                    data-toggle="collapse"
                    data-target="#{{target}}"
                    aria-expanded="{{#open}}true{{/open}}{{^open}}false{{/open}}"
                    aria-controls="{{target}}"
                >
                    {{title}}
                </button>
            </h2>
            <div
                id="{{target}}"
                class="accordion-collapse collapse{{#open}} show{{/open}}"
                aria-labelledby="heading-{{id}}"
                data-bs-parent="#ph-help-accordion"
                data-parent="#ph-help-accordion"
            >
                <div class="accordion-body text-muted">
                    {{content}}
                </div>
            </div>
        </div>
        {{/sections}}
    </div>

</div>
