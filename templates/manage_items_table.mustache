{{!
    @template block_playerhud/manage_items_table

    Displays the list of items for management.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "summary_text": "You have 5 items created and 3 drops available.",
        "summary_hint": "Click the drop button of an item to generate its shortcode.",
        "str_legend_title": "Drop button icons:",
        "str_legend_locations": "Number of locations where this item is hidden.",
        "str_legend_uses": "Total maximum collections across all finite locations.",
        "str_legend_infinite": "Infinite drops (no XP granted, unlimited collections).",
        "str_ai_create": "AI Create",
        "str_distribute": "Distribute Drops",
        "url_distribute": "#",
        "str_all_drops_btn": "View All Drops",
        "str_all_drops_more": "More drop options",
        "url_all_drops": "#",
        "url_add": "#",
        "str_add_item": "Add Item",
        "base_url": "#",
        "sesskey": "12345",
        "str_select_all": "Select all",
        "str_col_image": "Image",
        "headers": {
            "name": { "url": "#", "label": "Name", "icon_class": "fa-sort" },
            "xp": { "url": "#", "label": "XP", "icon_class": "fa-sort" },
            "enabled": { "url": "#", "label": "Enabled", "icon_class": "fa-sort" }
        },
        "str_col_drops": "Drops",
        "str_infinite_drops": "Infinite drops",
        "str_actions": "Actions",
        "items": [
            {
                "id": 1,
                "enabled": true,
                "counter": 1,
                "preview_attributes": "data-foo='bar'",
                "is_image": true,
                "image_url": "http://example.com/test.png",
                "name": "Magic Potion",
                "secret": false,
                "description_html": "Restores mana",
                "xp": 100,
                "image_content": "",
                "str_secret": "Secret item",
                "str_yes": "Yes",
                "str_no": "No",
                "url_toggle": "#",
                "str_hide": "Hide",
                "str_show": "Show",
                "url_drops": "#",
                "btn_drops_class": "btn-info",
                "str_manage_drops": "Manage Drops",
                "drops_total_uses": 6,
                "drops_has_finite": true,
                "drops_has_infinite": false,
                "drops_count": 2,
                "url_edit": "#",
                "str_edit": "Edit",
                "url_delete": "#",
                "str_delete": "Delete",
                "confirm_msg": "Are you sure?",
                "str_select": "Select"
            }
        ],
        "str_empty": "No items found.",
        "str_delete_selected": "Delete Selected",
        "paging_bar": "",
        "modal_ai_html": "",
        "modal_preview_html": ""
    }
}}
<div class="d-flex flex-column mb-3 p-3 bg-light rounded border shadow-sm ph-manage-header">
    <div class="d-flex justify-content-between align-items-center w-100 flex-wrap gap-2">
        <div class="d-flex align-items-center flex-grow-1">
            <button class="btn btn-link p-0 text-primary text-decoration-none me-2" type="button"
                    data-toggle="collapse" data-bs-toggle="collapse"
                    data-target="#ph-summary-hint" data-bs-target="#ph-summary-hint"
                    aria-expanded="false" aria-controls="ph-summary-hint"
                    aria-label="{{#str}} help_btn, block_playerhud {{/str}}">
                <i class="fa fa-question-circle fa-lg" aria-hidden="true"></i>
            </button>
            <span class="fw-bold text-dark">{{summary_text}}</span>
        </div>

        <div class="d-flex flex-wrap">
            <div class="btn-group me-2" role="group">
                <a href="{{url_distribute}}" class="btn btn-warning shadow-sm">
                    <i class="fa fa-random me-1" aria-hidden="true"></i> {{str_distribute}}
                </a>
                <button type="button"
                        class="btn btn-warning dropdown-toggle dropdown-toggle-split shadow-sm"
                        data-bs-toggle="dropdown" data-toggle="dropdown"
                        aria-expanded="false"
                        aria-label="{{str_all_drops_more}}">
                </button>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item" href="{{url_distribute}}">
                            <i class="fa fa-random me-1" aria-hidden="true"></i> {{str_distribute}}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="{{url_all_drops}}">
                            <i class="fa fa-list me-1" aria-hidden="true"></i> {{str_all_drops_btn}}
                        </a>
                    </li>
                </ul>
            </div>
            <button type="button" class="btn btn-info text-white shadow-sm me-2" id="btn-open-ai-modal">
                <i class="fa fa-magic me-1" aria-hidden="true"></i> {{str_ai_create}}
            </button>
            <a href="{{url_add}}" class="btn btn-primary shadow-sm">
                <i class="fa fa-plus-circle me-1" aria-hidden="true"></i> {{str_add_item}}
            </a>
        </div>
    </div>

    {{! Expandable Help Box (BS5 Collapse) }}
    <div class="collapse w-100" id="ph-summary-hint">
        <div class="alert alert-info border-info mb-0 mt-3 small py-2 shadow-sm d-flex align-items-start">
            <i class="fa fa-lightbulb-o fa-lg me-2 mt-1 text-warning" aria-hidden="true"></i>
            <div>
                <div>{{summary_hint}}</div>
                <hr class="my-2">
                <strong>{{str_legend_title}}</strong>
                <ul class="mb-0 mt-1 ps-3">
                    <li>
                        <i class="fa fa-map-marker" aria-hidden="true"></i>
                        {{str_legend_locations}}
                    </li>
                    <li>
                        <i class="fa fa-refresh" aria-hidden="true"></i>
                        {{str_legend_uses}}
                    </li>
                    <li>
                        <span aria-hidden="true">&#8734;</span>
                        {{str_legend_infinite}}
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<form action="{{base_url}}" method="post" id="bulk-action-form">
    <input type="hidden" name="action" value="bulk_delete">
    <input type="hidden" name="sesskey" value="{{sesskey}}">

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="bg-light border-bottom">
                        <tr class="text-nowrap">
                            <th scope="col" class="ph-col-select text-center align-middle">
                                <input type="checkbox" id="ph-select-all" class="form-check-input"
                                    title="{{str_select_all}}" aria-label="{{str_select_all}}">
                            </th>
                            <th scope="col" class="ph-col-sm text-center">{{#str}} col_number, block_playerhud {{/str}}</th>
                            <th scope="col" class="ph-col-md text-center">{{str_col_image}}</th>

                            <th scope="col">
                                <a href="{{headers.name.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                    {{headers.name.label}} <i class="fa {{headers.name.icon_class}} ms-1" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col" class="ph-col-lg">
                                 <a href="{{headers.xp.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                    {{headers.xp.label}} <i class="fa {{headers.xp.icon_class}} ms-1" aria-hidden="true"></i>
                                 </a>
                            </th>
                            <th scope="col" class="ph-col-xl">
                                <a href="{{headers.enabled.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                    {{headers.enabled.label}} <i class="fa {{headers.enabled.icon_class}} ms-1" aria-hidden="true"></i>
                                </a>
                            </th>

                            <th scope="col" class="ph-col-xxl">{{str_col_drops}}</th>
                            <th scope="col" class="text-end ph-col-actions">{{str_actions}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#items}}
                        <tr{{^enabled}} class="opacity-50"{{/enabled}}>
                            <td class="ph-col-select text-center align-middle">
                                <input type="checkbox" name="bulk_ids[]" value="{{id}}" id="chk-item-{{id}}"
                                    class="form-check-input ph-bulk-check" aria-label="{{str_select}} {{name}}">
                            </td>
                            <td class="align-middle text-center text-muted small text-nowrap">{{counter}}</td>
                            <td class="align-middle text-center position-relative text-nowrap">
                                 <a href="#" class="ph-preview-trigger text-decoration-none d-block"
                                    data-name="{{preview_data_name}}"
                                    data-xp="{{preview_data_xp}}"
                                    data-image="{{preview_data_image}}"
                                    data-isimage="{{preview_data_isimage}}"
                                    data-desc-target="desc_hidden_{{id}}" aria-label="{{name}}">
                                    {{#is_image}}
                                        <img src="{{image_url}}" class="ph-img-xs" alt="">
                                    {{/is_image}}
                                    {{^is_image}}
                                        <span class="ph-font-size-24" aria-hidden="true">{{image_content}}</span>
                                    {{/is_image}}
                                 </a>
                            </td>
                            <td class="align-middle">
                                 <a href="#" class="ph-preview-trigger fw-bold"
                                    data-name="{{preview_data_name}}"
                                    data-xp="{{preview_data_xp}}"
                                    data-image="{{preview_data_image}}"
                                    data-isimage="{{preview_data_isimage}}"
                                    data-desc-target="desc_hidden_{{id}}">
                                     {{name}}
                                    {{#secret}}
                                        <i class="fa fa-user-secret text-warning ms-1"
                                            role="img" aria-label="({{str_secret}})"></i>
                                    {{/secret}}
                                 </a>
                                <div id="desc_hidden_{{id}}" class="d-none">{{{description_html}}}</div>
                            </td>
                            <td class="align-middle text-nowrap">
                                <span class="badge bg-primary text-white">+{{xp}} XP</span>
                            </td>
                            <td class="align-middle text-nowrap">
                                {{#enabled}}
                                    <span class="badge bg-success text-white">{{str_yes}}</span>
                                    <a href="{{url_toggle}}" class="btn btn-sm btn-light border ms-1" aria-label="{{str_hide}} {{name}}">
                                        <i class="fa fa-eye text-success" aria-hidden="true"></i>
                                    </a>
                                {{/enabled}}
                                {{^enabled}}
                                    <span class="badge bg-secondary text-white">{{str_no}}</span>
                                    <a href="{{url_toggle}}" class="btn btn-sm btn-warning ms-1" aria-label="{{str_show}} {{name}}">
                                        <i class="fa fa-eye-slash" aria-hidden="true"></i>
                                    </a>
                                {{/enabled}}
                            </td>
                            <td class="align-middle text-nowrap">
                                <a href="{{url_drops}}" class="btn btn-sm {{btn_drops_class}} w-100" aria-label="{{str_manage_drops}}">
                                    <i class="fa fa-map-marker" aria-hidden="true"></i> <strong>{{drops_count}}</strong>
                                    {{#drops_has_finite}}
                                        <span class="ms-1 border-start ps-1">
                                            <i class="fa fa-refresh" aria-hidden="true"></i> <strong>{{drops_total_uses}}</strong>
                                        </span>
                                    {{/drops_has_finite}}
                                    {{#drops_has_infinite}}
                                        <span class="ms-1 border-start ps-1" aria-label="{{str_infinite_drops}}">&#8734;</span>
                                    {{/drops_has_infinite}}
                                </a>
                            </td>
                            <td class="align-middle text-end text-nowrap">
                                <a href="{{url_edit}}" class="btn btn-sm btn-primary me-1 shadow-sm" aria-label="{{str_edit}} {{name}}">
                                   <i class="fa fa-pencil" aria-hidden="true"></i>
                                   <span class="d-none d-xl-inline ms-1">{{str_edit}}</span>
                                </a>
                                <a href="{{url_delete}}" class="btn btn-sm btn-danger shadow-sm js-delete-btn"
                                    aria-label="{{str_delete}} {{name}}" data-confirm-msg="{{confirm_msg}}">
                                    <i class="fa fa-trash" aria-hidden="true"></i>
                                    <span class="d-none d-xl-inline ms-1">{{str_delete}}</span>
                                </a>
                            </td>
                        </tr>
                        {{/items}}
                        {{^items}}
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">{{str_empty}}</td>
                        </tr>
                        {{/items}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-danger shadow-sm disabled" id="ph-btn-bulk-delete" disabled>
            <i class="fa fa-trash me-1" aria-hidden="true"></i> {{str_delete_selected}}
        </button>
    </div>
</form>

{{{paging_bar}}}
{{{modal_ai_html}}}
{{{modal_preview_html}}}
