{{!
    Single choice card rendered inside the scene editor form.

    @template   block_playerhud/form_choice_card
    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "idx": 0,
        "choice_title": "Choice #1",
        "str_logic_badge": "Logic",
        "str_text": "Button Text",
        "val_text": "",
        "str_target": "Next Scene",
        "target_options": [
            {"value": "0", "label": "— End of chapter —", "selected": true},
            {"value": "-1", "label": "— Create new scene —", "selected": false}
        ],
        "str_req_hdr": "Requirements",
        "str_req_class": "Required Class",
        "req_class_options": [
            {"value": "0", "label": "--- None ---", "selected": true}
        ],
        "str_req_karma": "Min. Karma",
        "val_req_karma": 0,
        "str_cons_hdr": "Consequences",
        "str_karma": "Karma Delta",
        "val_karma": 0,
        "str_set_class": "Assign Class",
        "set_class_options": [
            {"value": "0", "label": "--- None ---", "selected": true}
        ],
        "str_cost_item": "Cost Item",
        "cost_item_options": [
            {"value": "0", "label": "--- None ---", "selected": true}
        ],
        "str_cost_qty": "Quantity",
        "val_cost_qty": 1
    }
}}
<div class="card ph-choice-card p-2 mb-3 border-start border-5 border-primary">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold text-primary m-0">{{choice_title}}</h6>
        <div class="d-flex align-items-center gap-2">
            <label class="small fw-bold text-muted mb-0"
                   for="id_choice_next_{{idx}}">{{str_target}}</label>
            <select id="id_choice_next_{{idx}}"
                    name="choice_next_{{idx}}"
                    class="form-select form-select-sm ph-choice-next-select">
                {{#target_options}}
                <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                {{/target_options}}
            </select>
            <span class="badge bg-light text-dark border ms-1">{{str_logic_badge}}</span>
        </div>
    </div>
    <div class="mb-2">
        <label class="small fw-bold text-muted"
               for="id_choice_text_{{idx}}">{{str_text}}</label>
        <input type="text"
               id="id_choice_text_{{idx}}"
               name="choice_text_{{idx}}"
               value="{{val_text}}"
               class="form-control form-control-sm"
               placeholder="...">
    </div>
    <div class="row border-top pt-2 mt-1">
        <div class="col-md-5 border-end">
            <small class="ph-choice-section-label text-uppercase text-danger fw-bold">
                {{str_req_hdr}}
            </small>
            <div class="row g-1 mt-1">
                <div class="col">
                    <label class="small text-muted mb-0"
                           for="id_choice_req_class_{{idx}}">{{str_req_class}}</label>
                    <select id="id_choice_req_class_{{idx}}"
                            name="choice_req_class_{{idx}}"
                            class="form-select form-select-sm">
                        {{#req_class_options}}
                        <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                        {{/req_class_options}}
                    </select>
                </div>
                <div class="col-auto">
                    <label class="small text-muted mb-0"
                           for="id_choice_req_karma_{{idx}}">{{str_req_karma}}</label>
                    <input type="number"
                           id="id_choice_req_karma_{{idx}}"
                           name="choice_req_karma_{{idx}}"
                           value="{{val_req_karma}}"
                           class="form-control form-control-sm ph-choice-field-number">
                </div>
            </div>
        </div>
        <div class="col-md-7 ps-3">
            <small class="ph-choice-section-label text-uppercase text-success fw-bold">
                {{str_cons_hdr}}
            </small>
            <div class="row g-1 mt-1">
                <div class="col-auto">
                    <label class="small text-muted mb-0"
                           for="id_choice_karma_{{idx}}">{{str_karma}}</label>
                    <input type="number"
                           id="id_choice_karma_{{idx}}"
                           name="choice_karma_{{idx}}"
                           value="{{val_karma}}"
                           class="form-control form-control-sm ph-choice-field-number">
                </div>
                <div class="col">
                    <label class="small text-muted mb-0"
                           for="id_choice_set_class_{{idx}}">{{str_set_class}}</label>
                    <select id="id_choice_set_class_{{idx}}"
                            name="choice_set_class_{{idx}}"
                            class="form-select form-select-sm">
                        {{#set_class_options}}
                        <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                        {{/set_class_options}}
                    </select>
                </div>
                <div class="col">
                    <label class="small text-muted mb-0"
                           for="id_choice_cost_{{idx}}">{{str_cost_item}}</label>
                    <select id="id_choice_cost_{{idx}}"
                            name="choice_cost_{{idx}}"
                            class="form-select form-select-sm">
                        {{#cost_item_options}}
                        <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                        {{/cost_item_options}}
                    </select>
                </div>
                <div class="col-auto">
                    <label class="small text-muted mb-0"
                           for="id_choice_cost_qty_{{idx}}">{{str_cost_qty}}</label>
                    <input type="number"
                           id="id_choice_cost_qty_{{idx}}"
                           name="choice_cost_qty_{{idx}}"
                           value="{{val_cost_qty}}"
                           class="form-control form-control-sm ph-choice-field-number">
                </div>
            </div>
        </div>
    </div>
</div>
