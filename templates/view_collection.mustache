{{!
    @template block_playerhud/view_collection
    @package block_playerhud
    @copyright 2026 Jean Lúcio
    @license https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "has_items": true,
        "show_filter": true,
        "sort_options": [
            { "value": "#", "label": "Recent", "selected": true }
        ],
        "items": [
            {
                "card_class": "ph-owned",
                "tabindex": "0",
                "id": 1,
                "name": "Sword",
                "count": 5,
                "badge_new": true,
                "is_image": false,
                "image_content": "⚔️",
                "date_str": "Jan 01"
            }
        ]
    }
}}
{{#has_items}}

{{! TOOLBAR / FILTER }}
{{#show_filter}}
<div class="d-flex justify-content-end mb-3">
    <div class="d-flex align-items-center">
        <label for="ph-collection-sort" class="me-2 small text-muted fw-bold">
            <i class="fa fa-sort" aria-hidden="true"></i> {{#str}} sort_by, block_playerhud {{/str}}
        </label>
        <select id="ph-collection-sort" class="form-select form-select-sm shadow-sm border-secondary w-auto ph-sort-selector"
                aria-label="{{#str}} sort_by, block_playerhud {{/str}}">
            {{#sort_options}}
                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
            {{/sort_options}}
        </select>
    </div>
</div>
{{/show_filter}}

<div class="playerhud-inventory-grid animate__animated animate__fadeIn">
    {{#items}}
    <div class="playerhud-item-card card {{card_class}} ph-item-trigger ph-cursor-pointer h-100 position-relative"
         role="button"
         tabindex="{{tabindex}}"
         data-id="{{id}}"
         data-name="{{name}}"
         data-count="{{count}}"
         data-image="{{data_image_payload}}"
         data-isimage="{{is_image_bool}}"
         {{#count}}
         data-timestamp="{{timestamp}}"
         data-date="{{date_str}}"
         {{/count}}
         aria-label="{{name}}">

        {{! NEW BADGE }}
        {{#badge_new}}
            <span class="ph-new-badge">{{#str}} new_item_badge, block_playerhud {{/str}}</span>
        {{/badge_new}}

        {{! ARCHIVED BADGE }}
        {{#badge_archived}}
            <span class="ph-badge-archived">
                {{#str}} item_archived, block_playerhud {{/str}}
            </span>
        {{/badge_archived}}

        {{! MODAL STYLE ITEM COUNTER (Dark with "x") }}
        {{#count}}
            <span class="badge bg-dark text-white rounded-pill position-absolute shadow-sm ph-count-badge"
                  title="{{#str}} qty, block_playerhud {{/str}}">
                x{{count}}
            </span>
        {{/count}}

        <div class="d-none ph-item-description-content">{{{description}}}</div>

        <div class="card-body p-2 d-flex flex-column align-items-center">

            {{! 1. Icon }}
            <div class="mt-3 mb-2 text-center ph-card-icon-container">
                 {{#is_image}}
                    <img src="{{image_url}}" class="ph-modal-img ph-card-img" alt="" aria-hidden="true">
                 {{/is_image}}
                 {{^is_image}}
                     <div class="ph-modal-emoji ph-card-emoji" aria-hidden="true">{{{image_content}}}</div>
                 {{/is_image}}
            </div>

            {{! 2. Name }}
            <div class="text-center w-100 mb-2 mt-2">
                <div class="fw-bold ph-card-title mb-1 ph-text-md" title="{{name}}">{{name}}</div>
            </div>

            <div class="mt-auto w-100 text-center">
                 {{#has_origins}}
                <div class="ph-card-origins mb-1 mt-2">
                    {{#origin_map}}<span class="me-1" title="{{#str}} legend_origins, block_playerhud {{/str}}"><i class="fa fa-map-o text-primary" aria-hidden="true"></i> {{origin_map}}</span>{{/origin_map}}
                    {{#origin_shop}}<span class="me-1" title="{{#str}} tab_shop, block_playerhud {{/str}}"><i class="fa fa-shopping-cart text-success" aria-hidden="true"></i> {{origin_shop}}</span>{{/origin_shop}}
                    {{#origin_quest}}<span class="me-1" title="{{#str}} report_src_quest, block_playerhud {{/str}}"><i class="fa fa-bullseye text-danger" aria-hidden="true"></i> {{origin_quest}}</span>{{/origin_quest}}
                    {{#origin_teacher}}<span class="me-1" title="{{#str}} report_src_teacher, block_playerhud {{/str}}"><i class="fa fa-gift text-info" aria-hidden="true"></i> {{origin_teacher}}</span>{{/origin_teacher}}
                    {{#origin_legacy}}<span title="{{#str}} legend_legacy, block_playerhud {{/str}}"><i class="fa fa-star text-warning" aria-hidden="true"></i> {{origin_legacy}}</span>{{/origin_legacy}}
                </div>
                {{/has_origins}}

                <div class="ph-card-date">{{{date_str}}}</div>
            </div>

            {{#has_power}}
            <div class="ph-card-actions border-top mt-2 pt-2 px-1 w-100">

                {{#is_avatar}}
                {{#is_equipped}}
                <span class="badge bg-success mb-1 d-block">
                    <i class="fa fa-check me-1" aria-hidden="true"></i>{{#str}} item_equipped_badge, block_playerhud {{/str}}
                </span>
                {{/is_equipped}}
                <button type="button"
                        class="btn btn-sm w-100 ph-item-equip-btn {{#is_equipped}}btn-outline-danger{{/is_equipped}}{{^is_equipped}}btn-outline-success{{/is_equipped}}"
                        data-itemid="{{itemid}}"
                        aria-pressed="{{is_equipped}}">
                    {{#is_equipped}}{{#str}} item_unequip, block_playerhud {{/str}}{{/is_equipped}}
                    {{^is_equipped}}{{#str}} item_equip, block_playerhud {{/str}}{{/is_equipped}}
                </button>
                {{/is_avatar}}

                {{#is_deadline}}
                {{#lp_warning}}
                <p class="small text-muted mb-1">
                    <i class="fa fa-exclamation-circle me-1" aria-hidden="true"></i>{{#str}} item_lp_warning, block_playerhud {{/str}}
                </p>
                {{/lp_warning}}
                {{^lp_warning}}
                {{#lp_has_multiple}}
                <select class="form-select form-select-sm mb-1 ph-lp-activity-select"
                        aria-label="{{#str}} item_use_pick_activity, block_playerhud {{/str}}">
                    <option value="">{{#str}} item_use_pick_activity, block_playerhud {{/str}}</option>
                    {{#lp_activities}}
                    <option value="{{cmid}}">{{name}}</option>
                    {{/lp_activities}}
                </select>
                {{/lp_has_multiple}}
                {{^lp_has_multiple}}
                {{#lp_activities}}
                <input type="hidden" class="ph-lp-activity-select" value="{{cmid}}">
                {{/lp_activities}}
                {{/lp_has_multiple}}
                <button type="button"
                        class="btn btn-sm btn-outline-warning w-100 ph-item-use-btn"
                        data-itemid="{{itemid}}">
                    {{#str}} item_use, block_playerhud {{/str}}
                </button>
                {{/lp_warning}}
                {{/is_deadline}}

            </div>
            {{/has_power}}

        </div>
    </div>
    {{/items}}
</div>

{{! LEGEND }}
<div class="mt-4 pt-3 border-top d-flex flex-wrap justify-content-center small text-muted align-items-center">
    <span class="fw-bold text-dark mx-3 my-1"><i class="fa fa-info-circle me-1" aria-hidden="true"></i>{{#str}} legend, block_playerhud {{/str}}</span>
    <span class="mx-3 my-1"><i class="fa fa-map-o text-primary me-1" aria-hidden="true"></i> {{#str}} legend_origins, block_playerhud {{/str}}</span>
    <span class="mx-3 my-1"><i class="fa fa-shopping-cart text-success me-1" aria-hidden="true"></i> {{#str}} tab_shop, block_playerhud {{/str}}</span>
    <span class="mx-3 my-1"><i class="fa fa-bullseye text-danger me-1" aria-hidden="true"></i> {{#str}} report_src_quest, block_playerhud {{/str}}</span>
    <span class="mx-3 my-1"><i class="fa fa-gift text-info me-1" aria-hidden="true"></i> {{#str}} report_src_teacher, block_playerhud {{/str}}</span>
</div>
{{/has_items}}

{{^has_items}}
<div class="alert alert-light border text-center py-5">
    <div class="ph-empty-state-icon" aria-hidden="true">📭</div>
    <p class="mb-0 text-muted">{{#str}} empty, block_playerhud {{/str}}</p>
</div>
{{/has_items}}
