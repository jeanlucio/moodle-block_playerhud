{{!
    @template block_playerhud/view_story

    Template for the student story chapter list and reading modal.

    Classes:
    * .ph-tab-story              - Root wrapper
    * .ph-chapter-item           - Base chapter list item
    * .ph-chapter-item--available - Clickable, not yet started
    * .ph-chapter-item--completed - Completed chapter
    * .ph-chapter-item--locked    - Future chapter (disabled)
    * .ph-story-modal-content    - Modal container
    * .ph-story-modal-header     - Modal header (dark)
    * .ph-story-modal-body       - Modal body (parchment)
    * .ph-story-modal-footer     - Modal footer (choices)
    * .ph-story-content          - Scene text container

    Example context (json):
    {
        "has_chapters": true,
        "str_story": "Story",
        "str_close": "Close",
        "str_empty": "No chapters available.",
        "str_loading": "Loading...",
        "str_completed": "Chapter completed!",
        "str_read_again": "Read again",
        "str_filter_by": "Filter by",
        "str_filter_all": "All",
        "str_filter_read": "Read",
        "str_filter_unread": "Unread",
        "chapters": [
            {
                "id": 1,
                "title": "Chapter One",
                "status_icon": "fa-book text-primary",
                "item_classes": "ph-chapter-item ph-chapter-item--available",
                "is_available": true,
                "is_completed": false,
                "is_locked": false,
                "chapter_status": "available",
                "str_recap": "Read recap"
            }
        ]
    }
}}
<div class="ph-tab-story">

    {{#has_chapters}}
    <div class="d-flex justify-content-end mb-3">
        <div class="d-flex align-items-center">
            <label for="ph-story-filter" class="me-2 small text-muted fw-bold">
                <i class="fa fa-filter" aria-hidden="true"></i> {{str_filter_by}}
            </label>
            <select id="ph-story-filter"
                    class="form-select form-select-sm shadow-sm border-secondary w-auto ph-story-filter-selector"
                    aria-label="{{str_filter_by}}">
                <option value="all">{{str_filter_all}}</option>
                <option value="unread">{{str_filter_unread}}</option>
                <option value="read">{{str_filter_read}}</option>
            </select>
        </div>
    </div>

    <div class="playerhud-inventory-grid animate__animated animate__fadeIn" id="ph-story-grid">
        {{#chapters}}
        <div class="playerhud-item-card card {{item_classes}}"
             data-status="{{chapter_status}}"
             {{#is_available}}
             data-action="open-chapter"
             data-chapterid="{{id}}"
             data-title="{{title}}"
             data-bs-toggle="modal"
             data-bs-target="#ph-story-modal"
             data-toggle="modal"
             data-target="#ph-story-modal"
             role="button"
             tabindex="0"
             {{/is_available}}>

            <div class="card-body p-3 d-flex flex-column align-items-center h-100">
                <div class="ph-card-icon-container ph-chapter-icon-container mb-2">
                    <i class="fa {{status_icon}} ph-chapter-status-icon" aria-hidden="true"></i>
                </div>

                <div class="text-center w-100 ph-chapter-title-wrap">
                    <div class="fw-bold ph-card-title mb-0" title="{{title}}">{{title}}</div>
                </div>

                <div class="mt-auto w-100 text-center">
                    {{#is_completed}}
                    <div class="ph-chapter-recap-wrap">
                        <button class="btn btn-sm btn-outline-info w-100"
                                data-action="read-recap"
                                data-chapterid="{{id}}"
                                data-title="{{title}}"
                                data-bs-toggle="modal"
                                data-bs-target="#ph-story-modal"
                                data-toggle="modal"
                                data-target="#ph-story-modal">
                            <i class="fa fa-history" aria-hidden="true"></i> {{str_recap}}
                        </button>
                    </div>
                    {{/is_completed}}
                </div>
            </div>
        </div>
        {{/chapters}}
    </div>
    {{/has_chapters}}

    {{^has_chapters}}
    <div class="alert alert-light text-center py-5">
        <i class="fa fa-book fa-2x mb-2 d-block" aria-hidden="true"></i>
        {{str_empty}}
    </div>
    {{/has_chapters}}

    {{! Story reading modal }}
    <div class="modal fade" id="ph-story-modal" tabindex="-1" aria-hidden="true"
         aria-labelledby="ph-story-title" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content ph-story-modal-content">
                <div class="modal-header ph-story-modal-header">
                    <h5 class="modal-title fw-bold" id="ph-story-title">
                        <i class="fa fa-book me-2" aria-hidden="true"></i> {{str_story}}
                    </h5>
                    <button type="button" class="ph-modal-close-btn"
                            data-bs-dismiss="modal" data-dismiss="modal"
                            aria-label="{{str_close}}">
                        <i class="fa fa-times" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="modal-body ph-story-modal-body">
                    <div id="ph-story-content" class="ph-story-content">
                        <div class="text-center text-muted py-5">
                            <i class="fa fa-circle-o-notch fa-spin fa-3x" aria-hidden="true"></i>
                            <p class="mt-2">{{str_loading}}</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer ph-story-modal-footer justify-content-center"
                     id="ph-story-choices"></div>
            </div>
        </div>
    </div>

</div>
