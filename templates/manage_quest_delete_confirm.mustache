{{!
    @template block_playerhud/manage_quest_delete_confirm

    Confirmation screen shown before deleting quests that students already claimed, warning
    about the XP that would be reverted.

    Context variables required for this template:
    * heading - Pre-formatted, safe heading text.
    * has_xp_impact - Whether any student would lose recorded XP.
    * xp_impact_warning - Aggregate XP impact message (student count + total XP).
    * has_disable_link - Whether to show the "disable instead" link (single quest only).
    * disable_url - URL of the disable-instead link.
    * str_disable_suggestion - Suggestion text pointing at disabling instead of deleting.
    * str_disable_instead - Disable-instead link label.
    * form_action - URL the confirmation form posts to.
    * sesskey - Session key.
    * action - Form action value (delete_quest_force or bulk_delete_quests_force).
    * is_bulk - Whether this confirms a bulk deletion.
    * quest_id - The single quest ID (when not bulk).
    * bulk_ids - Array of quest IDs (when bulk), each with an id.
    * sort - Current sort column carried through the form.
    * dir - Current sort direction carried through the form.
    * cancel_url - URL of the cancel button.
    * str_cancel - Cancel button label.
    * confirm_label - Submit button label.

    Example context (json):
    {
        "heading": "Bonus Quest",
        "has_xp_impact": true,
        "xp_impact_warning": "This quest has already been claimed by 2 student(s), totalling 400 XP. Deleting it will permanently take that XP back.",
        "has_disable_link": true,
        "disable_url": "https://example.com/manage.php?action=toggle_quest&questid=5",
        "str_disable_suggestion": "If you don't want to affect these students' XP, disable the quest instead of deleting it.",
        "str_disable_instead": "Disable instead",
        "form_action": "https://example.com/manage.php",
        "sesskey": "abc123",
        "action": "delete_quest_force",
        "is_bulk": false,
        "quest_id": 5,
        "bulk_ids": [],
        "sort": "id",
        "dir": "DESC",
        "cancel_url": "https://example.com/manage.php?tab=quests",
        "str_cancel": "Cancel",
        "confirm_label": "Delete quest"
    }
}}
<div class="block-playerhud-delete-confirm">
    <h3 class="h3">{{{heading}}}</h3>
    {{#has_xp_impact}}
        <div class="alert alert-warning" role="alert">
            {{xp_impact_warning}}
            <div class="mt-2 small">
                {{str_disable_suggestion}}
                {{#has_disable_link}}
                    <a href="{{disable_url}}" class="alert-link">{{str_disable_instead}}</a>
                {{/has_disable_link}}
            </div>
        </div>
    {{/has_xp_impact}}
    <form method="post" action="{{form_action}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <input type="hidden" name="action" value="{{action}}">
        <input type="hidden" name="tab" value="quests">
        <input type="hidden" name="sort" value="{{sort}}">
        <input type="hidden" name="dir" value="{{dir}}">
        {{^is_bulk}}
            <input type="hidden" name="questid" value="{{quest_id}}">
        {{/is_bulk}}
        {{#bulk_ids}}
            <input type="hidden" name="bulk_ids[]" value="{{id}}">
        {{/bulk_ids}}
        <a href="{{cancel_url}}" class="btn btn-secondary me-2">{{str_cancel}}</a>
        <button type="submit" class="btn btn-danger">{{confirm_label}}</button>
    </form>
</div>
