{{!
    @template block_playerhud/tab_reports

    Template for the Reports tab in PlayerHUD management.

    @package    block_playerhud
    @copyright  2026 Jean Lúcio <jeanlucio@gmail.com>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    Example context (json):
    {
        "is_audit": false,
        "str": {
            "audit": "Audit",
            "leaderboard": "Leaderboard",
            "action": "Action",
            "no_logs": "No logs found",
            "filter_btn": "Filter",
            "filter_clr": "Clear",
            "col_desc": "Element",
            "col_details": "Details",
            "btn_showall": "Show all",
            "btn_showpaged": "Show 30 per page",
            "summary": "Summary"
        },
        "kpis": [{"title": "Total XP", "value": "1500", "subtitle": "", "bg_class": "ph-bg-gradient-primary"}],
        "has_students": true,
        "user_selector": { "options": [{"value": 1, "label": "Jean Lúcio", "selected": true}] },
        "url_export": "#"
    }
}}
<div class="playerhud-reports-container animate__animated animate__fadeIn">

    {{! --- 1. OVERVIEW CARDS --- }}
    <div class="row mb-4">
        {{#kpis}}
        <div class="col-md-4 mb-3 mb-md-0">
            <div class="card border-0 shadow-sm text-white {{bg_class}}">
                <div class="card-body">
                    <h6 class="text-uppercase ph-opacity-80">{{title}}</h6>
                    <h4 class="fw-bold mb-0 text-truncate">{{value}}</h4>
                    <small>{{subtitle}}</small>
                </div>
            </div>
        </div>
        {{/kpis}}
    </div>

    {{! --- 2. GAME STATS (Charts) --- }}
    <div class="row mb-4">

        {{! Level distribution }}
        <div class="col-md-6 mb-3 mb-md-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">
                    <i class="fa fa-bar-chart text-info" aria-hidden="true"></i> {{charts.str_levels}}
                </div>
                <div class="card-body overflow-auto ph-max-h-200">
                    {{#charts.has_levels}}
                        {{#charts.levels}}
                            <div class="d-flex align-items-center mb-1 small">
                                <div class="fw-bold ph-w-50">{{str.level}} {{label}}</div>
                                <div class="flex-grow-1 mx-2">
                                    <div class="progress ph-h-10" aria-hidden="true">
                                        <div class="progress-bar bg-info" style="width: {{percent}}%"></div>
                                    </div>
                                </div>
                                <div class="text-end ph-w-30">{{total}}</div>
                            </div>
                        {{/charts.levels}}
                    {{/charts.has_levels}}
                    {{^charts.has_levels}}
                        <div class="text-muted text-center">{{charts.str_no_logs}}</div>
                    {{/charts.has_levels}}
                </div>
            </div>
        </div>

        {{! Quest completions }}
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">
                    <i class="fa fa-list-alt text-warning" aria-hidden="true"></i> {{quest_stats.str_title}}
                </div>
                <div class="card-body">
                    {{#quest_stats.has_quests}}
                    <div class="d-flex gap-3 mb-3 small text-center flex-wrap">
                        <div class="flex-fill border rounded p-2">
                            <div class="fw-bold fs-5">{{quest_stats.total}}</div>
                            <div class="text-muted">{{quest_stats.str_total}}</div>
                        </div>
                        <div class="flex-fill border rounded p-2">
                            <div class="fw-bold fs-5 text-success">{{quest_stats.engaged}}</div>
                            <div class="text-muted">{{quest_stats.str_engaged}}</div>
                        </div>
                        <div class="flex-fill border rounded p-2">
                            <div class="fw-bold fs-5 text-danger">{{quest_stats.no_claims}}</div>
                            <div class="text-muted">{{quest_stats.str_no_claims}}</div>
                        </div>
                    </div>
                    <div class="overflow-auto ph-max-h-200">
                        {{#quest_stats.quests}}
                        <div class="d-flex align-items-center mb-1 small">
                            <div class="flex-grow-1 text-truncate me-2" title="{{label}}">{{label}}</div>
                            <div class="ph-w-80 mx-2">
                                <div class="progress ph-h-10" aria-hidden="true">
                                    <div class="progress-bar {{#no_claims}}bg-secondary{{/no_claims}}{{^no_claims}}bg-warning{{/no_claims}}"
                                         style="width: {{percent}}%"></div>
                                </div>
                            </div>
                            <div class="text-end ph-w-30">{{total}}</div>
                        </div>
                        {{/quest_stats.quests}}
                    </div>
                    {{/quest_stats.has_quests}}
                    {{^quest_stats.has_quests}}
                        <div class="text-muted text-center">{{quest_stats.str_no_data}}</div>
                    {{/quest_stats.has_quests}}
                </div>
            </div>
        </div>

    </div>

    {{! --- 3. STUDENT SELECTOR --- }}
    <div class="card mb-4 shadow-sm">
        <div class="card-body p-3 bg-light d-flex align-items-center flex-wrap">
            <strong class="me-3 mb-2 mb-md-0"><i class="fa fa-filter" aria-hidden="true"></i> {{str.audit}}</strong>
            <div class="flex-grow-1 ph-max-w-500">
                <label for="r_userid" class="sr-only visually-hidden">{{str.audit}}</label>
                <select id="r_userid" class="form-select w-100">
                    {{#user_selector.options}}
                        <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/user_selector.options}}
                </select>
            </div>
        </div>
    </div>

    {{! --- 4. MAIN AREA (Audit OR General Table) --- }}
    {{#is_audit}}
        <div class="mb-3 text-end">
            <a href="{{url_back}}" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="fa fa-arrow-left" aria-hidden="true"></i> {{str_back}}
            </a>
        </div>

        {{! --- LIVE SEARCH BAR & SHOW ALL TOGGLE --- }}
        <div class="mb-4 mt-3 d-flex gap-2 flex-wrap">
            <div class="input-group shadow-sm flex-grow-1 ph-min-w-250">
                <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted" aria-hidden="true"></i></span>
                <input type="text" id="ph-live-search" class="form-control border-start-0 ps-0" placeholder="{{str.search_any}}" aria-label="{{str.search_any}}">
            </div>
            <div>
                {{#showall}}
                    <a href="{{url_toggle_showall}}" class="btn btn-outline-primary shadow-sm h-100 d-flex align-items-center text-nowrap">
                        <i class="fa fa-compress me-2" aria-hidden="true"></i> {{str.btn_showpaged}}
                    </a>
                {{/showall}}
                {{^showall}}
                    <a href="{{url_toggle_showall}}" class="btn btn-outline-secondary shadow-sm h-100 d-flex align-items-center text-nowrap">
                        <i class="fa fa-expand me-2" aria-hidden="true"></i> {{str.btn_showall}}
                    </a>
                {{/showall}}
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center p-3 flex-wrap gap-2">
                <span class="fw-bold"><i class="fa fa-history" aria-hidden="true"></i> {{str.audit}}</span>

                {{! MANUAL ITEM GRANTING }}
                {{#has_available_items}}
                <form action="{{grant_action_url}}" method="post" class="d-flex align-items-center m-0">
                    <input type="hidden" name="id" value="{{courseid}}">
                    <input type="hidden" name="instanceid" value="{{instanceid}}">
                    <input type="hidden" name="action" value="grant_item">
                    <input type="hidden" name="r_userid" value="{{r_userid}}">
                    <input type="hidden" name="sesskey" value="{{sesskey}}">

                    <div class="input-group input-group-sm">
                        <select name="itemid" class="form-select border-success" required aria-label="{{str.grant_item_select}}">
                            <option value="">-- {{str.grant_item_select}} --</option>
                            {{#available_items}}
                                <option value="{{value}}">{{label}}</option>
                            {{/available_items}}
                        </select>
                        <button type="submit" class="btn btn-success fw-bold" aria-label="{{str.grant_item_select}}">
                            <i class="fa fa-gift" aria-hidden="true"></i>
                        </button>
                    </div>
                </form>
                {{/has_available_items}}
            </div>

            <div class="card-body p-0 table-responsive">
                {{#has_audit_logs}}
                <table class="table table-hover table-striped bg-white mb-0 align-middle w-100">
                    <thead class="bg-light border-bottom">
                        <tr class="text-nowrap">
                            <th scope="col" class="text-center text-muted ps-3 ph-w-50">{{str.col_num}}</th>
                            <th scope="col">
                                <a href="{{audit_headers.date.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                    {{audit_headers.date.label}} <i class="fa {{audit_headers.date.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col">
                                <a href="{{audit_headers.type.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                    {{audit_headers.type.label}} <i class="fa {{audit_headers.type.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col">
                                <a href="{{audit_headers.element.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                    {{audit_headers.element.label}} <i class="fa {{audit_headers.element.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col" class="text-center">
                                <a href="{{audit_headers.xp.url}}" class="text-dark text-decoration-none d-flex align-items-center justify-content-center">
                                    {{audit_headers.xp.label}} <i class="fa {{audit_headers.xp.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col">
                                <a href="{{audit_headers.details.url}}" class="text-dark text-decoration-none d-flex align-items-center">
                                    {{audit_headers.details.label}} <i class="fa {{audit_headers.details.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col" class="text-end pe-3">{{str.action}}</th>
                        </tr>
                    </thead>
                    <tbody id="ph-history-tbody">
                        {{#audit_logs}}
                        <tr class="ph-searchable-row">
                            <td class="text-center text-muted small ps-3">{{counter}}</td>
                            <td class="text-muted small text-nowrap">{{date}}</td>
                            <td><span class="badge {{badge_class}}">{{badge_text}}</span></td>
                            <td class="fw-bold">
                                <div class="d-flex align-items-center">
                                    <div class="me-2 text-center ph-w-30">
                                        {{#is_image_icon}}<img src="{{icon_url}}" class="ph-img-xs" alt="">{{/is_image_icon}}
                                        {{^is_image_icon}}<span class="fs-5" aria-hidden="true">{{icon_emoji}}</span>{{/is_image_icon}}
                                    </div>
                                    <div>{{object_name}}</div>
                                </div>
                            </td>
                            <td class="text-center">{{{xp_badge}}}</td>
                            <td class="text-muted small text-wrap ph-table-details-col">{{{details_html}}}</td>
                            <td class="text-end pe-3">
                                {{#has_revoke}}
                                    <a href="{{url_revoke}}" class="btn btn-sm btn-outline-danger js-delete-report-btn text-nowrap"
                                        data-bs-toggle="tooltip"
                                        title="{{str.revoke_item}}"
                                        aria-label="{{str.revoke_item}} {{object_name}}"
                                        data-confirm-msg="{{str.confirm_revoke}}">
                                        <i class="fa fa-trash" aria-hidden="true"></i> <span class="ms-1">{{str.delete}}</span>
                                    </a>
                                {{/has_revoke}}
                            </td>
                        </tr>
                        {{/audit_logs}}
                    </tbody>
                </table>
                {{/has_audit_logs}}
                {{^has_audit_logs}}
                    <div class="alert alert-info m-3">{{str.no_logs}}</div>
                {{/has_audit_logs}}
            </div>
        </div>

        {{{paging_bar}}}

    {{/is_audit}}

    {{^is_audit}}
        {{#has_students}}
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span><i class="fa fa-list" aria-hidden="true"></i> {{str.leaderboard}} ({{str.summary}})</span>
                <div class="d-flex gap-2">
                    <a href="{{url_export}}&amp;format=csv" class="btn btn-sm btn-outline-success shadow-sm" title="{{str.export_csv}}">
                        <i class="fa fa-download" aria-hidden="true"></i> <span class="d-none d-md-inline">{{str.export_csv}}</span>
                    </a>
                    <a href="{{url_export}}&amp;format=excel" class="btn btn-sm btn-outline-success shadow-sm" title="{{str.export_excel}}">
                        <i class="fa fa-file-excel-o" aria-hidden="true"></i> <span class="d-none d-md-inline">{{str.export_excel}}</span>
                    </a>
                </div>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover table-striped mb-0 text-center align-middle">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th scope="col" class="ph-col-sm text-center text-muted">{{str.col_num}}</th>
                            <th scope="col" class="text-start ps-3">
                                <a href="{{headers.student.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                                    {{headers.student.label}} <i class="fa {{headers.student.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col">
                                <a href="{{headers.xp.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center justify-content-center">
                                    {{headers.xp.label}} <i class="fa {{headers.xp.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col">
                                <a href="{{headers.items.url}}" class="text-dark text-decoration-none fw-bold d-flex align-items-center justify-content-center">
                                    {{headers.items.label}} <i class="fa {{headers.items.icon_class}}" aria-hidden="true"></i>
                                </a>
                            </th>
                            <th scope="col" class="text-center text-muted small"><i class="fa fa-clock-o" aria-hidden="true"></i> {{str.last_action}}</th>
                            <th scope="col" class="fw-bold pe-3 text-dark">{{str.action}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#students}}
                        <tr class="{{row_class}}">
                            <td class="text-center text-muted small fw-bold">{{counter}}</td>
                            <td class="text-start ps-3">
                                <a href="{{url_audit}}" class="{{name_class}}" data-bs-toggle="tooltip" title="{{str.audit}}">{{fullname}}</a>
                            </td>
                            <td>
                                {{#is_active}}
                                    <span class="badge bg-success text-white ph-text-sm">{{str.level}} {{level}}</span><br>
                                    <small class="text-muted">{{xp}} XP</small>
                                {{/is_active}}
                            </td>
                            <td><span class="badge bg-light text-dark border">{{total_items}}</span></td>
                            <td class="text-center text-muted small font-monospace">{{last_action}}</td>
                            <td class="pe-3">
                                <a href="{{url_audit}}" class="btn btn-sm btn-outline-primary text-nowrap" data-bs-toggle="tooltip" title="{{str.audit}}" aria-label="{{str.audit}} {{fullname}}">
                                    <i class="fa fa-search" aria-hidden="true"></i> <span class="ms-1">{{str.view}}</span>
                                </a>
                            </td>
                        </tr>
                        {{/students}}
                    </tbody>
                </table>
            </div>
        </div>
        {{/has_students}}
        {{^has_students}}
             <div class="alert alert-warning">{{str.no_logs}}</div>
        {{/has_students}}
    {{/is_audit}}

    {{! --- 5. AI LOGS --- }}
    {{#has_ai_logs}}
        <hr class="my-5">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
                <span><i class="fa fa-magic" aria-hidden="true"></i> {{str.ai_title}}</span>
                <small>{{str.ai_sub}}</small>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover mb-0 text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-start">{{str.col_date}}</th>
                            <th scope="col">{{str.action}}</th>
                            <th scope="col">{{str.col_object}}</th>
                            <th scope="col">{{str.col_ai}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#ai_logs}}
                        <tr {{#is_hidden}}class="ph-ai-hidden" style="display:none;"{{/is_hidden}}>
                            <td class="text-start small">{{date}}</td>
                            <td><span class="badge bg-light text-dark border">{{action_badge}}</span></td>
                            <td><span aria-hidden="true">{{type_icon}}</span> <strong>{{object_name}}</strong></td>
                            <td><span class="badge {{ai_class}} px-3">{{ai_provider}}</span></td>
                        </tr>
                        {{/ai_logs}}
                    </tbody>
                </table>
                <div class="text-center p-2 bg-light border-top">
                    <button id="btn-ai-toggle" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-chevron-down me-1" aria-hidden="true"></i> {{str.btn_more}}
                    </button>
                </div>
            </div>
        </div>
    {{/has_ai_logs}}

</div>
